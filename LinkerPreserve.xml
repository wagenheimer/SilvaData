  <assembly fullname="Syncfusion.Maui.Buttons" preserve="all" />
  <assembly fullname="Syncfusion.Maui.DataGrid" preserve="all" />
  <assembly fullname="Syncfusion.Maui.Gauges" preserve="all" />
  <assembly fullname="Syncfusion.Maui.ImageEditor" preserve="all" />
  <assembly fullname="Syncfusion.Maui.Inputs" preserve="all" />
  <assembly fullname="Syncfusion.Maui.ListView" preserve="all" />
