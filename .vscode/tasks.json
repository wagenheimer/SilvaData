{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "iOS: Publish (SilvaData)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "publish",
        "/Volumes/Sandisk/Projects/CWSoftware/SilvaData/SilvaData.csproj",
        "-f",
        "net10.0-ios",
        "-c",
        "Release",
        "-p:RuntimeIdentifier=ios-arm64",
        "-p:ArchiveOnBuild=true",
        "-p:ProvisioningType=Automatic",
        "-p:CodesignKey=Apple Development",
        "-p:CodesignProvision="
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    }
  ]
}
