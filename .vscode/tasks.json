{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "iOS: Build Release (Device)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/SilvaData.csproj",
        "-f", "net10.0-ios",
        "-c", "Release",
        "-r", "ios-arm64",
        "-p:ProvisioningType=Automatic",
        "-p:CodesignKey=Apple Development"
      ],
      "group": { "kind": "build", "isDefault": true },
      "problemMatcher": "$msCompile",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "iOS: Run Release (iPad)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "build",
        "${workspaceFolder}/SilvaData.csproj",
        "-t:Run",
        "-f", "net10.0-ios",
        "-c", "Release",
        "-r", "ios-arm64",
        "-p:ProvisioningType=Automatic",
        "-p:CodesignKey=Apple Development",
        "-p:_DeviceName=:v2:udid=149adb0791157b04687efca608cb62a446b69856"
      ],
      "group": "build",
      "problemMatcher": "$msCompile",
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "iOS: Publish (SilvaData)",
      "type": "shell",
      "command": "dotnet",
      "args": [
        "publish",
        "/Volumes/Sandisk/Projects/CWSoftware/SilvaData/SilvaData.csproj",
        "-f",
        "net10.0-ios",
        "-c",
        "Release",
        "-p:RuntimeIdentifier=ios-arm64",
        "-p:ArchiveOnBuild=true",
        "-p:ProvisioningType=Automatic",
        "-p:CodesignKey=Apple Development",
        "-p:CodesignProvision="
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    }
  ]
}
