<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="SilvaData.Controls.LoadingView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:SilvaData.Controls"
    x:Name="loadingView"
    x:DataType="controls:LoadingView"
    HorizontalOptions="Fill"
    VerticalOptions="Fill">

    <Grid
        BindingContext="{x:Reference loadingView}"
        HorizontalOptions="Fill"
        VerticalOptions="Fill">

        <BoxView
            BackgroundColor="Black"
            HorizontalOptions="Fill"
            Opacity="0.5"
            VerticalOptions="Fill" />

        <Border
            Padding="30,20"
            BackgroundColor="White"
            HorizontalOptions="Center"
            StrokeShape="RoundRectangle 10"
            StrokeThickness="0"
            VerticalOptions="Center">

            <VerticalStackLayout
                HorizontalOptions="Center"
                Spacing="20"
                VerticalOptions="Center">

                <ActivityIndicator
                    HorizontalOptions="Center"
                    IsRunning="True"
                    VerticalOptions="Center"
                    Color="{Binding IndicatorColor}" />

                <Label
                    x:Name="LoadingInfo"
                    Margin="10,0"
                    FontAttributes="Bold"
                    FontSize="18"
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"
                    Text="{Binding Text}"
                    TextColor="{Binding TextColor}" />

            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentView>
