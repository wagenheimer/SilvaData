<?xml version="1.0" encoding="utf-8" ?>
<utils:ContentPageWithLocalization
    x:Class="ISIInstitute.Views.MinhaConta"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
    xmlns:fontawesome="clr-namespace:SilvaData.FontAwesome"
    xmlns:localization="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui"
    xmlns:models="clr-namespace:SilvaData.Models"
    xmlns:utils="clr-namespace:SilvaData.Utils"
    xmlns:viewmodels="clr-namespace:SilvaData.ViewModels"
    Title="{localization:Translate MinhaConta}"
    x:DataType="viewmodels:MinhaContaViewModel"
    BackgroundColor="{StaticResource PrimaryColor}"
    Shell.TabBarIsVisible="false">

    <ContentPage.Content>
        <ScrollView>
            <Grid
                Padding="{StaticResource LayoutPadding}"
                BackgroundColor="{StaticResource QuaseBranco}"
                RowDefinitions="Auto,Auto,*,Auto"
                RowSpacing="{StaticResource LayoutSpacing}">

                <Grid
                    Grid.Row="0"
                    Margin="0,0,0,5"
                    ColumnDefinitions="*,Auto"
                    RowDefinitions="Auto">

                    <Label
                        Padding="0"
                        SemanticProperties.HeadingLevel="Level1"
                        Style="{StaticResource Title2}"
                        Text="{localization:Translate MinhaConta}"
                        TextColor="{StaticResource PrimaryColor}" />

                    <buttons:SfButton
                        Grid.Column="1"
                        Command="{Binding VoltarCommand}"
                        Style="{StaticResource CircleButton}"
                        Text="{x:Static fontawesome:FontAwesomeIcons.TurnDownLeft}" />
                </Grid>

                <Label
                    Grid.Row="1"
                    Margin="0,0,0,5"
                    Style="{StaticResource Caption1}"
                    Text="{localization:Translate VejaDadosConta}"
                    TextColor="Gray" />

                <Grid
                    Grid.Row="2"
                    RowDefinitions="Auto,*,Auto"
                    RowSpacing="{StaticResource LayoutSpacing}">

                    <Border
                        Grid.Row="0"
                        Margin="0,0,0,10"
                        Padding="15"
                        Style="{StaticResource CardStyle}">

                        <Grid
                            x:Name="userinfo"
                            x:DataType="models:dataLoginResult"
                            BindingContext="{Binding LoggedUser}"
                            ColumnDefinitions="Auto,*"
                            ColumnSpacing="15"
                            RowSpacing="4">

                            <Label
                                Grid.Column="0"
                                FontFamily="FontAwesomeLight"
                                FontSize="50"
                                Text="{x:Static fontawesome:FontAwesomeIcons.CircleUser}"
                                TextColor="{StaticResource ButtonColor}"
                                VerticalTextAlignment="Center" />

                            <Grid
                                Grid.Column="1"
                                ColumnDefinitions="*"
                                RowDefinitions="Auto,Auto">
                                <Label
                                    Grid.Row="0"
                                    FontAttributes="Bold"
                                    FontSize="Title"
                                    HorizontalTextAlignment="Start"
                                    Text="{Binding nome}"
                                    TextColor="{StaticResource SecondaryColor}" />
                                <Label
                                    Grid.Row="1"
                                    HorizontalTextAlignment="Start"
                                    Style="{StaticResource Body2}"
                                    Text="{Binding email}"
                                    TextColor="{StaticResource DarkOnLightBackground}" />
                            </Grid>
                        </Grid>
                    </Border>

                    <VerticalStackLayout
                        Grid.Row="1"
                        Spacing="8"
                        VerticalOptions="Center">

                        <buttons:SfButton
                            x:Name="downloadDataWeb"
                            Margin="0"
                            Background="Red"
                            Command="{Binding DownloadDataWebCommand}"
                            CornerRadius="10"
                            HeightRequest="50"
                            IsVisible="{Binding IsDebug}"
                            Text="Baixar dados da Web"
                            TextColor="White" />
                        <buttons:SfButton
                            x:Name="goToLogin"
                            Margin="0"
                            Background="Red"
                            Command="{Binding GoToLoginWithoutLogOffCommand}"
                            CornerRadius="10"
                            HeightRequest="50"
                            IsVisible="{Binding IsDebug}"
                            Text="Faz novo login, sem dar Log Off"
                            TextColor="White" />
                        <buttons:SfButton
                            x:Name="compartilhaDB"
                            Margin="0"
                            Background="Red"
                            Command="{Binding CompartilhaDBCommand}"
                            CornerRadius="10"
                            HeightRequest="50"
                            IsVisible="{Binding IsDebug}"
                            Text="Compartilhar Banco de Dados"
                            TextColor="White" />
                        <buttons:SfButton
                            x:Name="enviarReset"
                            Margin="0"
                            Background="Red"
                            Command="{Binding EnviarResetCommand}"
                            CornerRadius="10"
                            HeightRequest="50"
                            IsVisible="{Binding IsDebug}"
                            Text="Enviar Metodos Reset"
                            TextColor="White" />

                        <buttons:SfButton
                            Margin="0,10,0,0"
                            Command="{Binding LogOffCommand}"
                            CornerRadius="20"
                            HeightRequest="70"
                            HorizontalOptions="Center"
                            ShowIcon="False"
                            Style="{StaticResource sfButtonWhite}">
                            <buttons:SfButton.Content>
                                <DataTemplate>
                                    <HorizontalStackLayout
                                        Padding="10"
                                        HorizontalOptions="Center"
                                        Spacing="10"
                                        VerticalOptions="Center">
                                        <Label
                                            FontFamily="FontAwesomeRegular"
                                            Text="{x:Static fontawesome:FontAwesomeIcons.ArrowRightFromBracket}"
                                            TextColor="{StaticResource PrimaryColor}"
                                            VerticalTextAlignment="Center" />
                                        <Label
                                            Text="{localization:Translate DeslogarConta}"
                                            TextColor="{StaticResource PrimaryColor}"
                                            VerticalTextAlignment="Center" />
                                    </HorizontalStackLayout>
                                </DataTemplate>
                            </buttons:SfButton.Content>
                        </buttons:SfButton>
                    </VerticalStackLayout>

                    <Border
                        Grid.Row="2"
                        Margin="0,10,0,0"
                        Padding="10"
                        Style="{StaticResource CardStyle}">
                        <Grid
                            ColumnDefinitions="Auto,*"
                            ColumnSpacing="20"
                            RowDefinitions="Auto,Auto"
                            RowSpacing="4">

                            <Label
                                Grid.Row="0"
                                Grid.Column="0"
                                HorizontalTextAlignment="End"
                                Style="{StaticResource Caption1Strong}"
                                Text="{localization:Translate NumeroDoDispositivo}"
                                TextColor="Gray" />
                            <Label
                                Grid.Row="0"
                                Grid.Column="1"
                                HorizontalTextAlignment="Start"
                                Style="{StaticResource Caption1}"
                                Text="{Binding LoggedUser.dispositivoId}"
                                TextColor="Gray" />

                            <Label
                                Grid.Row="1"
                                Grid.Column="0"
                                HorizontalTextAlignment="End"
                                Style="{StaticResource Caption1Strong}"
                                Text="{localization:Translate Sessăo}"
                                TextColor="Gray" />
                            <Label
                                Grid.Row="1"
                                Grid.Column="1"
                                HorizontalTextAlignment="Start"
                                Style="{StaticResource Caption1}"
                                Text="{Binding LoggedUser.session}"
                                TextColor="Gray" />
                        </Grid>
                    </Border>
                </Grid>


            </Grid>
        </ScrollView>
    </ContentPage.Content>
</utils:ContentPageWithLocalization>
