<?xml version="1.0" encoding="UTF-8" ?>
<controls:ValidatableFieldBase
    x:Class="SilvaData.Controls.YesNoToggle"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:SilvaData.Controls"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
    xmlns:fontawesome="clr-namespace:SilvaData.FontAwesome"
    xmlns:models="clr-namespace:SilvaData.Models"
    x:Name="yesNoToggle"
    Padding="2">

    <controls:ValidatableFieldBase.Resources>
        <!-- Estilo local para ignorar o VSM global que força fundo verde -->
        <Style x:Key="ToggleButtonStyle" TargetType="buttons:SfButton">
            <Setter Property="VisualStateManager.VisualStateGroups">
                <VisualStateGroupList>
                    <VisualStateGroup x:Name="CommonStates">
                        <VisualState x:Name="Normal" />
                        <VisualState x:Name="Pressed">
                            <VisualState.Setters>
                                <Setter Property="Scale" Value="0.95" />
                                <Setter Property="Opacity" Value="0.8" />
                            </VisualState.Setters>
                        </VisualState>
                        <VisualState x:Name="Disabled">
                            <VisualState.Setters>
                                <Setter Property="Opacity" Value="0.5" />
                            </VisualState.Setters>
                        </VisualState>
                    </VisualStateGroup>
                </VisualStateGroupList>
            </Setter>
            <Setter Property="MinimumHeightRequest" Value="0" />
            <Setter Property="MinimumWidthRequest" Value="0" />
            <Setter Property="TextTransform" Value="None" />
            <Setter Property="Shadow" Value="{x:Null}" />
        </Style>
    </controls:ValidatableFieldBase.Resources>

    <Border
        Padding="0,10"
        Background="Transparent"
        Stroke="{StaticResource PrimaryColor}"
        StrokeShape="RoundRectangle 8"
        StrokeThickness="0">

        <Border.Triggers>
            <DataTrigger
                Binding="{Binding HasError, Source={x:Reference yesNoToggle}}"
                TargetType="Border"
                Value="True">
                <Setter Property="Stroke" Value="Red" />
                <Setter Property="StrokeThickness" Value="2" />
            </DataTrigger>
        </Border.Triggers>

        <Grid ColumnDefinitions="*,60,60" RowDefinitions="Auto" x:DataType="models:ParametroComAlternativas" ColumnSpacing="5">

            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center" Padding="10,0">
                <Label
                    Grid.Column="0"
                    FontSize="Small"
                    Text="{Binding nome}"
                    TextColor="{Binding TextColor, Source={x:Reference yesNoToggle}}"
                    VerticalTextAlignment="Center" />
                <Label
                    Grid.Column="1"
                    Margin="2,0,0,0"
                    Padding="0"
                    FontAttributes="Bold"
                    FontSize="Small"
                    IsVisible="{Binding ShowRequiredStar, Source={x:Reference yesNoToggle}}"
                    Text="*"
                    TextColor="Red"
                    VerticalTextAlignment="Center" />
            </Grid>

            <!-- Botão Sim -->
            <buttons:SfButton
                x:Name="btYes"
                Grid.Column="1"
                Padding="0"
                Clicked="BtYes_Clicked"
                CornerRadius="8"
                FontAttributes="Bold"
                FontFamily="FontAwesomeRegular"
                FontSize="20"
                HeightRequest="44"
                WidthRequest="50"
                Text="{x:Static fontawesome:FontAwesomeIcons.Check}"
                VerticalOptions="Center">
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="Background" Value="{Binding YesBrush, Source={x:Reference yesNoToggle}}" />
                                    <Setter Property="TextColor" Value="{Binding YesTextColor, Source={x:Reference yesNoToggle}}" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Pressed">
                                <VisualState.Setters>
                                    <Setter Property="Background" Value="{Binding YesBrush, Source={x:Reference yesNoToggle}}" />
                                    <Setter Property="TextColor" Value="{Binding YesTextColor, Source={x:Reference yesNoToggle}}" />
                                    <Setter Property="Opacity" Value="0.7" />
                                    <Setter Property="Scale" Value="0.95" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
            </buttons:SfButton>

            <!-- Botão Não -->
            <buttons:SfButton
                x:Name="btNo"
                Grid.Column="2"
                Padding="0"
                Clicked="BtNo_Clicked"
                CornerRadius="8"
                FontAttributes="Bold"
                FontFamily="FontAwesomeRegular"
                FontSize="20"
                HeightRequest="44"
                WidthRequest="50"
                Text="{x:Static fontawesome:FontAwesomeIcons.X}"
                VerticalOptions="Center">
                <VisualStateManager.VisualStateGroups>
                    <VisualStateGroupList>
                        <VisualStateGroup x:Name="CommonStates">
                            <VisualState x:Name="Normal">
                                <VisualState.Setters>
                                    <Setter Property="Background" Value="{Binding NoBrush, Source={x:Reference yesNoToggle}}" />
                                    <Setter Property="TextColor" Value="{Binding NoTextColor, Source={x:Reference yesNoToggle}}" />
                                </VisualState.Setters>
                            </VisualState>
                            <VisualState x:Name="Pressed">
                                <VisualState.Setters>
                                    <Setter Property="Background" Value="{Binding NoBrush, Source={x:Reference yesNoToggle}}" />
                                    <Setter Property="TextColor" Value="{Binding NoTextColor, Source={x:Reference yesNoToggle}}" />
                                    <Setter Property="Opacity" Value="0.7" />
                                    <Setter Property="Scale" Value="0.95" />
                                </VisualState.Setters>
                            </VisualState>
                        </VisualStateGroup>
                    </VisualStateGroupList>
                </VisualStateManager.VisualStateGroups>
            </buttons:SfButton>
        </Grid>
    </Border>
</controls:ValidatableFieldBase>