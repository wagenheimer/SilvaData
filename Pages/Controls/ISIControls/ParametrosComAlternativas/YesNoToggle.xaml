<?xml version="1.0" encoding="UTF-8" ?>
<controls:ValidatableFieldBase
    x:Class="SilvaData.Controls.YesNoToggle"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:SilvaData.Controls"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
    xmlns:fontawesome="clr-namespace:SilvaData.FontAwesome"
    x:Name="yesNoToggle"
    Padding="2">

    <ContentView.Resources>
        <!-- Estilo local para ignorar o VSM global que força fundo branco -->
        <Style x:Key="ToggleButtonStyle" TargetType="buttons:SfButton">
         
        </Style>
    </ContentView.Resources>

    <Border
        Padding="10,10"
        Background="Transparent"
        Stroke="{StaticResource PrimaryColor}"
        StrokeShape="RoundRectangle 8"
        StrokeThickness="0">

        <Border.Triggers>
            <DataTrigger
                Binding="{Binding HasError, Source={x:Reference yesNoToggle}}"
                TargetType="Border"
                Value="True">
                <Setter Property="Stroke" Value="Red" />
                <Setter Property="StrokeThickness" Value="2" />
            </DataTrigger>
        </Border.Triggers>

        <Grid ColumnDefinitions="*,60,60" RowDefinitions="Auto">

            <!--  Label com nome do parâmetro + asterisco  -->
            <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                <Label
                    Grid.Column="0"
                    FontSize="Small"
                    Text="{Binding nome}"
                    TextColor="{Binding TextColor, Source={x:Reference yesNoToggle}}"
                    VerticalTextAlignment="Center" />
                <Label
                    Grid.Column="1"
                    Margin="2,0,0,0"
                    Padding="0"
                    FontAttributes="Bold"
                    FontSize="Small"
                    Text="*"
                    TextColor="Red"
                    VerticalTextAlignment="Center">
                    <Label.Triggers>
                        <DataTrigger
                            Binding="{Binding required}"
                            TargetType="Label"
                            Value="1">
                            <Setter Property="IsVisible" Value="True" />
                        </DataTrigger>
                        <DataTrigger
                            Binding="{Binding required}"
                            TargetType="Label"
                            Value="0">
                            <Setter Property="IsVisible" Value="False" />
                        </DataTrigger>
                        <DataTrigger
                            Binding="{Binding required}"
                            TargetType="Label"
                            Value="{x:Null}">
                            <Setter Property="IsVisible" Value="False" />
                        </DataTrigger>
                    </Label.Triggers>
                </Label>
            </Grid>

            <!--  Botão Sim  -->
            <buttons:SfButton
                x:Name="btYes"
                Grid.Column="1"
                Padding="0"
                Background="{Binding YesColor, Source={x:Reference yesNoToggle}}"
                Clicked="BtYes_Clicked"
                CornerRadius="40"
                FontAttributes="Bold"
                FontFamily="FontAwesomeRegular"
                FontSize="20"
                HeightRequest="50"
                ShowIcon="False"
                Style="{StaticResource ToggleButtonStyle}"
                Text="{x:Static fontawesome:FontAwesomeIcons.Check}"
                TextColor="{Binding YesTextColor, Source={x:Reference yesNoToggle}}"
                VerticalOptions="Center" />

            <!--  Botão Não  -->
            <buttons:SfButton
                x:Name="btNo"
                Grid.Column="2"
                Padding="0"
                Background="{Binding NoColor, Source={x:Reference yesNoToggle}}"
                Clicked="BtNo_Clicked"
                CornerRadius="40"
                FontAttributes="Bold"
                FontFamily="FontAwesomeRegular"
                FontSize="20"
                HeightRequest="50"
                ShowIcon="False"
                Style="{StaticResource ToggleButtonStyle}"
                Text="{x:Static fontawesome:FontAwesomeIcons.X}"
                TextColor="{Binding NoTextColor, Source={x:Reference yesNoToggle}}"
                VerticalOptions="Center" />
        </Grid>
    </Border>
</controls:ValidatableFieldBase>
