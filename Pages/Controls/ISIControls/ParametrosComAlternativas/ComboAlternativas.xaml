<?xml version="1.0" encoding="UTF-8" ?>
<controls:ValidatableFieldBase
    x:Class="SilvaData.Controls.ComboAlternativas"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:SilvaData.Controls"
    xmlns:combobox="clr-namespace:Syncfusion.Maui.Inputs;assembly=Syncfusion.Maui.Inputs"
    xmlns:localization="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui"
    xmlns:local="clr-namespace:SilvaData"
    x:Name="comboAlternativas">
    <Grid Padding="2" RowDefinitions="Auto,Auto" RowSpacing="4">
            <!--  Título + asterisco de obrigatório  -->
            <Grid
                Grid.Row="0"
                Padding="0"
                ColumnDefinitions="*,Auto">
                <Label
                    x:Name="labelTitle"
                    Grid.Column="0"
                    Margin="0"
                    Padding="5,0"
                    FontSize="Small"
                    Text="{Binding nome}"
                    TextColor="{StaticResource PrimaryColor}" />
                <Label
                    Grid.Column="1"
                    Margin="2,0,0,0"
                    Padding="0"
                    FontAttributes="Bold"
                    FontSize="Small"
                    IsVisible="{Binding ShowRequiredStar, Source={x:Reference comboAlternativas}}"
                    Text="*"
                    TextColor="Red"
                    VerticalTextAlignment="Center" />
            </Grid>

            <!--  Campo de seleção  -->
            <Border
                Grid.Row="1"
                Margin="0"
                Padding="12,0"
                Background="White"
                HeightRequest="52"
                Stroke="{StaticResource PrimaryColor}"
                StrokeShape="RoundRectangle 8"
                StrokeThickness="1">

                <Border.Triggers>
                    <DataTrigger
                        Binding="{Binding HasError, Source={x:Reference comboAlternativas}}"
                        TargetType="Border"
                        Value="True">
                        <Setter Property="Stroke" Value="Red" />
                        <Setter Property="StrokeThickness" Value="2" />
                    </DataTrigger>
                </Border.Triggers>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OpenComboBox" />
                </Border.GestureRecognizers>

                <combobox:SfComboBox
                    x:Name="ComboBox"
                    Margin="0"
                    BackgroundColor="Transparent"
                    DisplayMemberPath="descricao"
                    HeightRequest="52"
                    IsEnabled="{Binding Source={x:Reference comboAlternativas}, Path=NotIsReadOnly}"
                    Placeholder="{localization:Translate Selecione}"
                    ShowBorder="False" />
            </Border>
    </Grid>
</controls:ValidatableFieldBase>
