<?xml version="1.0" encoding="UTF-8" ?>
<controls:ValidatableFieldBase
    x:Class="SilvaData.Controls.ValorInteiroComBotoes"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:fontawesome="clr-namespace:SilvaData.FontAwesome"
    xmlns:controls="clr-namespace:SilvaData.Controls"
    xmlns:models="clr-namespace:SilvaData.Models"
    x:Name="valorInteiro">

    <controls:ValidatableFieldBase.Content>
        <StackLayout Padding="2" Spacing="4" x:DataType="models:ParametroComAlternativas">

            <!--  Título + asterisco de obrigatório  -->
            <Grid ColumnDefinitions="*,Auto">
                <Label
                    x:Name="labelTitle"
                    Grid.Column="0"
                    Margin="0"
                    Padding="5,0"
                    FontSize="Small"
                    Text="{Binding nome}"
                    TextColor="{StaticResource PrimaryColor}" />
                <Label
                    Grid.Column="1"
                    Margin="2,0,0,0"
                    Padding="0"
                    FontAttributes="Bold"
                    FontSize="Small"
                    IsVisible="{Binding ShowRequiredStar, Source={x:Reference valorInteiro}}"
                    Text="*"
                    TextColor="Red"
                    VerticalTextAlignment="Center" />
            </Grid>

            <Border
                x:Name="valorInteiroBorder"
                Margin="0"
                Padding="12,0"
                Background="White"
                HeightRequest="52"
                Stroke="{StaticResource PrimaryColor}"
                StrokeShape="RoundRectangle 8"
                StrokeThickness="1">

                <Border.Triggers>
                    <DataTrigger
                        Binding="{Binding HasError, Source={x:Reference valorInteiro}}"
                        TargetType="Border"
                        Value="True">
                        <Setter Property="Stroke" Value="Red" />
                        <Setter Property="StrokeThickness" Value="2" />
                    </DataTrigger>
                </Border.Triggers>
                <controls:ISINumericUpDown
                    x:Name="innerNumeric"
                    FontSize="{OnIdiom 18, Desktop=24}"
                    IsReadOnly="{Binding IsReadOnly, Source={x:Reference valorInteiro}}"
                    Maximum="{Binding ParametroComAlternativas.valorMaximo, Source={x:Reference valorInteiro}}"
                    Minimum="{Binding ParametroComAlternativas.valorMinimo, Source={x:Reference valorInteiro}}"
                    TextColor="{Binding IsReadOnly, Source={x:Reference valorInteiro}, Converter={StaticResource BoolToColorConverter}}"
                    Value="{Binding Valor, Source={x:Reference valorInteiro}, Mode=TwoWay}" />
            </Border>

            <!--  Helper Text  -->
            <Label
                Margin="0"
                Padding="12,0"
                FontSize="Micro"
                IsVisible="{Binding ShowHelperText, Source={x:Reference valorInteiro}}"
                Text="{Binding HelperText, Source={x:Reference valorInteiro}}"
                TextColor="Gray" />
        </StackLayout>
    </controls:ValidatableFieldBase.Content>
</controls:ValidatableFieldBase>
