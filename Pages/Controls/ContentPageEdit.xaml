<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SilvaData.Controls.ContentPageEdit"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:Name="thisPage">

    <ContentPage.Behaviors>
        <toolkit:StatusBarBehavior StatusBarColor="{StaticResource Primary}" StatusBarStyle="LightContent" />
    </ContentPage.Behaviors>

    <!--  CORRIGIDO: Bindeia ao ViewModel diretamente (sem Source)  -->
    <Shell.BackButtonBehavior>
        <BackButtonBehavior Command="{Binding CheckSavedCommand}" />
    </Shell.BackButtonBehavior>

</ContentPage>
