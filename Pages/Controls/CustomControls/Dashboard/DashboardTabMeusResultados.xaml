<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="SilvaData.Controls.DashboardTabMeusResultados"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
    xmlns:controls="clr-namespace:SilvaData.Controls"
    xmlns:localization="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui" xmlns:safe="http://isisis.com.br/safe"
    xmlns:viewmodels="clr-namespace:SilvaData.ViewModels"
    x:DataType="viewmodels:DashboardViewModel">

    <VerticalStackLayout>
        <!--  ISI Score Card  -->
        <Border
                Margin="10,15,10,0"
                Padding="30,5,30,5"
                Background="White"
                Stroke="{StaticResource Gray200}"
                StrokeShape="RoundRectangle 30"
                StrokeThickness="2">
            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                <!--  ISI Score Total Text  -->
                <StackLayout
                        Grid.Row="0"
                        Grid.Column="0"
                        VerticalOptions="Center">
                    <Label
                            FontAttributes="Bold"
                            FontFamily="Nunito"
                            FontSize="Medium"
                            Text="ISI Score Total"
                            TextColor="{StaticResource PrimaryColor}" />
                    <Label
                            FontAttributes="Bold"
                            FontSize="Large"
                            HorizontalTextAlignment="Start"
                            Text="{Binding ISIScoreText}"
                            TextColor="{Binding ISIScoreTextColor}" />
                </StackLayout>

                <!--  Circular Gauge  -->
                <controls:CirculoScoreLote
                        Grid.Row="0"
                        Grid.Column="1"
                        Margin="45,0,0,0"
                        Padding="0"
                        HorizontalOptions="End"
                        Valor="{Binding ISIScoreTotal}" />

                <!--  Action Buttons Grid  -->
                <Grid
                        Grid.Row="1"
                        Grid.ColumnSpan="2"
                        Margin="0"
                        Padding="0"
                        ColumnDefinitions="1*,1*,1*"
                        ColumnSpacing="8"
                        RowDefinitions="Auto">
                    <Grid Grid.Column="0">
                        <buttons:SfButton
                                Margin="0"
                                Padding="0"
                                Background="{StaticResource ScoreBackground}"
                                Command="{Binding GraficoScoreCommand}"
                                ImageAlignment="Top"
                                ImageSize="25"
                                ImageSource="iconscore.png"
                                ShowIcon="True"
                                Text="{safe:Translate ScoreSemDoisPontos}"
                                TextColor="{StaticResource ScoreTextColor}" />
                    </Grid>

                    <Grid Grid.Column="1">
                        <buttons:SfButton
                                Margin="0"
                                Padding="0"
                                Background="{StaticResource AcometimentoBackground}"
                                Command="{Binding GraficoAcometimentoCommand}"
                                ImageAlignment="Top"
                                ImageSize="25"
                                ImageSource="iconacometimento.png"
                                ShowIcon="True"
                                Text="{safe:Translate Acomet}"
                                TextColor="{StaticResource AcometimentoTextColor}" />
                    </Grid>

                    <Grid Grid.Column="2">
                        <buttons:SfButton
                                Margin="0"
                                Padding="0"
                                Background="{StaticResource DispersaoBackground}"
                                Command="{Binding GraficoDispersaoCommand}"
                                ImageAlignment="Top"
                                ImageSize="25"
                                ImageSource="icondispersao.png"
                                ShowIcon="True"
                                Text="{safe:Translate Dispersão}"
                                TextColor="{StaticResource DispersaoTextColor}" />
                    </Grid>
                </Grid>

                <!--  Media Comparison Frame  -->
                <Border
                        Grid.Row="2"
                        Grid.ColumnSpan="2"
                        Margin="0,15"
                        Padding="10,15"
                        Background="{Binding MediaBackground}"
                        IsVisible="{Binding MeusResultadosVisible}"
                        Stroke="Transparent"
                        StrokeShape="RoundRectangle 30">
                    <Grid ColumnDefinitions="Auto,*">
                        <HorizontalStackLayout Grid.Column="0">
                            <Label
                                    Padding="5,0"
                                    FontFamily="FontAwesomeLight"
                                    FontSize="Medium"
                                    Text="{Binding MediaIcon}"
                                    TextColor="{Binding MediaTextColor}"
                                    VerticalOptions="Center" />
                            <Label
                                    Padding="5,0"
                                    FontSize="Small"
                                    Text="{Binding TextoMedia}"
                                    TextColor="{Binding MediaTextColor}"
                                    VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Label
                                Grid.Column="1"
                                FontSize="Micro"
                                HorizontalTextAlignment="Start"
                                Text="{Binding TextoMedia2}"
                                TextColor="Gray"
                                VerticalOptions="Center" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!--  IEP and Índice do Manejo Cards  -->
        <Grid
                Margin="0,10"
                Padding="10,0"
                ColumnDefinitions="1*,1*"
                ColumnSpacing="10">
            <Border
                    Grid.Column="0"
                    Padding="15"
                    Background="White"
                    Stroke="{StaticResource Gray200}"
                    StrokeShape="RoundRectangle 30"
                    StrokeThickness="2">
                <StackLayout>
                    <Label
                            FontAttributes="Bold"
                            FontSize="Large"
                            Text="{Binding DadosDashboard.mediaIEP}"
                            TextColor="{StaticResource PrimaryColor}" />
                    <Label
                            FontSize="Small"
                            Text="IEP"
                            TextColor="{StaticResource SecondaryColor}" />
                </StackLayout>
            </Border>
            <Border
                    Grid.Column="1"
                    Padding="15"
                    Background="White"
                    Stroke="{StaticResource Gray200}"
                    StrokeShape="RoundRectangle 30"
                    StrokeThickness="2">
                <StackLayout>
                    <Label
                            FontAttributes="Bold"
                            FontSize="Large"
                            Text="{Binding DadosDashboard.mediaScoreManejo}"
                            TextColor="{StaticResource PrimaryColor}" />
                    <Label
                            FontSize="Small"
                            Text="Índice do Manejo"
                            TextColor="{StaticResource SecondaryColor}" />
                </StackLayout>
            </Border>
        </Grid>
    </VerticalStackLayout>
</ContentView>
