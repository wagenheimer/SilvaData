<ContentView
    x:Class="SilvaData.Controls.GalpoesView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
    xmlns:listView="clr-namespace:Syncfusion.Maui.ListView;assembly=Syncfusion.Maui.ListView"
    xmlns:models="clr-namespace:SilvaData.Models"
    xmlns:viewModels="clr-namespace:SilvaData.ViewModels"
    x:DataType="viewModels:GalpoesViewModel">

    <Grid RowDefinitions="Auto,Auto,Auto,*" BackgroundColor="{StaticResource QuaseBranco}">

        <!-- ── Linha 0: Header com logo (igual à primeira página) ── -->
        <Grid Grid.Row="0" Padding="20,16,20,20">
            <Grid.Background>
                <LinearGradientBrush EndPoint="0,1">
                    <GradientStop Offset="0.0" Color="{StaticResource PrimaryLightColor}" />
                    <GradientStop Offset="1.0" Color="{StaticResource QuaseBranco}" />
                </LinearGradientBrush>
            </Grid.Background>
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" VerticalOptions="Center">
                <Image
                    Grid.Column="0"
                    HeightRequest="44"
                    WidthRequest="44"
                    Aspect="AspectFit"
                    Source="silvadatalogo" />
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="Silvadata"
                        TextColor="{StaticResource SecondaryColor}" />
                    <Label
                        FontSize="12"
                        Text="from Silvateam"
                        TextColor="{StaticResource Gray400}" />
                </VerticalStackLayout>
                <Label
                    Grid.Column="2"
                    FontAttributes="Bold"
                    FontSize="15"
                    HorizontalTextAlignment="End"
                    TextColor="{StaticResource PrimaryColor}"
                    VerticalOptions="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Galpões (" TextColor="{StaticResource PrimaryColor}"/>
                            <Span Text="{Binding TotalGalpoes}" TextColor="{StaticResource PrimaryColor}"/>
                            <Span Text=")" TextColor="{StaticResource PrimaryColor}"/>
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </Grid>
        </Grid>

        <!-- ── Linha 1: Título e subtítulo ── -->
        <!-- ── Linha 1: Barra de pesquisa ── -->
        <Border
            Grid.Row="1"
            Margin="16,0,16,8"
            Padding="12,0"
            BackgroundColor="White"
            HeightRequest="44"
            Stroke="{StaticResource PrimaryColor}"
            StrokeThickness="1.5"
            StrokeShape="RoundRectangle 10">
            <Grid ColumnDefinitions="Auto,*">
                <Label
                    Grid.Column="0"
                    FontFamily="FontAwesomeSolid"
                    FontSize="14"
                    Text="&#xf002;"
                    TextColor="{StaticResource Gray300}"
                    VerticalOptions="Center" />
                <Entry
                    Grid.Column="1"
                    Margin="8,0,0,0"
                    BackgroundColor="Transparent"
                    FontSize="14"
                    Placeholder="Pesquisar Galpão"
                    PlaceholderColor="{StaticResource Gray300}"
                    Text="{Binding TextoPesquisa, Mode=TwoWay}"
                    TextColor="{StaticResource DarkColor}"
                    VerticalOptions="Center" />
            </Grid>
        </Border>

        <!-- ── Linha 2: Cabeçalho das colunas ── -->
        <Grid
            Grid.Row="2"
            ColumnDefinitions="*,60,48,48"
            Padding="16,4,16,4">
            <Label
                Grid.Column="0"
                FontAttributes="Bold"
                FontSize="13"
                Text="Galpão"
                TextColor="{StaticResource PrimaryColor}" />
            <Label
                Grid.Column="1"
                FontAttributes="Bold"
                FontSize="13"
                HorizontalTextAlignment="Center"
                Text="Lotes"
                TextColor="{StaticResource PrimaryColor}" />
            <BoxView
                Grid.Column="0"
                Grid.ColumnSpan="4"
                BackgroundColor="{StaticResource PrimaryColor}"
                HeightRequest="1.5"
                VerticalOptions="End" />
        </Grid>

        <!-- ── Linha 4: Lista ── -->
        <!-- ── Linha 3: Lista ── -->
        <Grid Grid.Row="3">
            <listView:SfListView
                x:Name="listaGalpoes"
                ItemSize="56"
                ItemsSource="{Binding ListaFiltrada}"
                SelectionMode="None">

                <listView:SfListView.ItemTemplate>
                    <DataTemplate x:DataType="models:UnidadeEpidemiologicaComDetalhes">
                        <Grid
                            BackgroundColor="{StaticResource QuaseBranco}"
                            ColumnDefinitions="*,60,48,48"
                            Padding="16,0">
                            <Label
                                Grid.Column="0"
                                FontSize="14"
                                Text="{Binding nome}"
                                TextColor="{StaticResource DarkColor}"
                                VerticalOptions="Center" />
                            <Label
                                Grid.Column="1"
                                FontSize="14"
                                HorizontalTextAlignment="Center"
                                Text="{Binding QuantidadeLotes}"
                                TextColor="{StaticResource DarkColor}"
                                VerticalOptions="Center" />
                            <buttons:SfButton
                                Grid.Column="2"
                                Command="{Binding EditarCommand, Source={RelativeSource AncestorType={x:Type viewModels:GalpoesViewModel}}}"
                                CommandParameter="{Binding .}"
                                Background="Transparent"
                                FontFamily="FontAwesomeSolid"
                                FontSize="20"
                                ShowIcon="False"
                                Text="&#xf044;"
                                TextColor="{StaticResource SecondaryColor}"
                                VerticalOptions="Center" />
                            <buttons:SfButton
                                Grid.Column="3"
                                Command="{Binding ShowLoteCommand, Source={RelativeSource AncestorType={x:Type viewModels:GalpoesViewModel}}}"
                                x:DataType="x:Null"
                                CommandParameter="{Binding .}"
                                Background="Transparent"
                                FontFamily="FontAwesomeSolid"
                                FontSize="20"
                                ShowIcon="False"
                                Text="&#xf65e;"
                                TextColor="{StaticResource PrimaryColor}"
                                VerticalOptions="Center" />
                            <BoxView
                                Grid.Column="0"
                                Grid.ColumnSpan="4"
                                BackgroundColor="{StaticResource Gray100}"
                                HeightRequest="1"
                                VerticalOptions="End" />
                        </Grid>
                    </DataTemplate>
                </listView:SfListView.ItemTemplate>

                <listView:SfListView.ItemsLayout>
                    <listView:LinearLayout />
                </listView:SfListView.ItemsLayout>
            </listView:SfListView>

            <!-- FAB -->
            <buttons:SfButton
                Command="{Binding AdicionarGalpaoCommand}"
                IsVisible="{x:Static viewModels:GalpoesViewModel.PodeAdicionar}"
                Background="{StaticResource PrimaryBrush}"
                CornerRadius="28"
                HeightRequest="56"
                HorizontalOptions="End"
                Margin="0,0,20,20"
                VerticalOptions="End"
                WidthRequest="56"
                FontFamily="FontAwesomeSolid"
                FontSize="22"
                ShowIcon="False"
                Text="&#xf067;"
                TextColor="White" />
        </Grid>

    </Grid>
</ContentView>
