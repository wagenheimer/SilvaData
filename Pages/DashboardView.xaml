<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="SilvaData.Controls.DashboardView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
    xmlns:controls="clr-namespace:SilvaData.Controls"
    xmlns:fontawesome="clr-namespace:SilvaData.FontAwesome"
    xmlns:listView="clr-namespace:Syncfusion.Maui.ListView;assembly=Syncfusion.Maui.ListView"
    xmlns:localization="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui"
    xmlns:models="clr-namespace:SilvaData.Models"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:viewmodels="clr-namespace:SilvaData.ViewModels"
    x:Name="dashboardView"
    x:DataType="viewmodels:DashboardViewModel"
    Background="#26558D">

    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="0">

        <!--  Header Section  -->
        <Grid
            Grid.Row="0"
            Margin="0,0,0,0"
            Background="{StaticResource PrimaryGradientBrush}"
            ColumnDefinitions="Auto,*,Auto"
            RowDefinitions="Auto">
            <HorizontalStackLayout
                Grid.Row="0"
                Spacing="0"
                VerticalOptions="Center">

                <Image
                    Margin="10,0,0,0"
                    Aspect="AspectFit"
                    HeightRequest="30"
                    HorizontalOptions="Center"
                    Source="isilogo.png">

                    <Image.Shadow>
                        <Shadow
                            Brush="White"
                            Opacity="0.5"
                            Radius="10"
                            Offset="0,1" />
                    </Image.Shadow>

                </Image>

                <Label
                    Margin="5,0,2,0"
                    Padding="5,0"
                    FontAttributes="Bold"
                    FontFamily="Nunito"
                    FontSize="Large"
                    HorizontalTextAlignment="Start"
                    Text="ISI Sys"
                    TextColor="White"
                    VerticalOptions="Center" />
                <Label
                    Margin="0,6"
                    FontAttributes="Bold"
                    FontSize="Micro"
                    HorizontalTextAlignment="Start"
                    Text="from ISI Institute"
                    TextColor="White"
                    VerticalOptions="End"
                    VerticalTextAlignment="End" />
            </HorizontalStackLayout>
            <buttons:SfButton
                x:Name="userButton"
                Grid.Row="0"
                Grid.Column="2"
                Margin="10,10"
                Command="{Binding ShowUsuarioCommand}"
                CommandParameter="{x:Reference userButton}"
                CornerRadius="40"
                FontAttributes="Bold"
                FontSize="Large"
                HeightRequest="50"
                Style="{StaticResource NovoBotao}"
                Text="{x:Static fontawesome:FontAwesomeIcons.User}"
                WidthRequest="50" />
        </Grid>

        <!--  Background Layer  -->
        <StackLayout
            Grid.Row="1"
            Grid.RowSpan="2"
            Margin="0,40,0,0"
            Background="{StaticResource QuaseBranco}" />

        <!--  Tab View — implementação nativa  -->
        <Grid
            Grid.Row="1"
            RowDefinitions="40,Auto">

            <!--  Barra de abas  -->
            <Grid
                Grid.Row="0"
                Background="{StaticResource PrimaryGradientBrush}"
                ColumnDefinitions="1*,1*,1*">

                <!--  Tab 0: Meus Resultados  -->
                <Grid x:Name="tabHeader0" Grid.Column="0">
                    <Grid.Behaviors>
                        <toolkit:TouchBehavior
                            DefaultOpacity="1"
                            PressedAnimationDuration="100"
                            PressedOpacity="0.6" />
                    </Grid.Behaviors>
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding MeusResultadosCommand}" />
                    </Grid.GestureRecognizers>
                    <Label
                        x:Name="tabLabel0"
                        Margin="4,0"
                        FontSize="11"
                        HorizontalTextAlignment="Center"
                        Text="Meus Resultados"
                        TextColor="White"
                        VerticalTextAlignment="Center" />
                    <BoxView
                        HeightRequest="3"
                        Color="White"
                        HorizontalOptions="Fill"
                        IsVisible="{Binding IsMeusResultadosTabVisible}"
                        VerticalOptions="End" />
                </Grid>

                <!--  Tab 1: Empresa  -->
                <Grid x:Name="tabHeader1" Grid.Column="1">
                    <Grid.Behaviors>
                        <toolkit:TouchBehavior
                            DefaultOpacity="1"
                            PressedAnimationDuration="100"
                            PressedOpacity="0.6" />
                    </Grid.Behaviors>
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding EmpresaCommand}" />
                    </Grid.GestureRecognizers>
                    <Label
                        x:Name="tabLabel1"
                        FontSize="11"
                        HorizontalTextAlignment="Center"
                        Opacity="0.55"
                        Text="Empresa"
                        TextColor="White"
                        VerticalTextAlignment="Center" />
                    <BoxView
                        HeightRequest="3"
                        Color="White"
                        HorizontalOptions="Fill"
                        IsVisible="{Binding IsEmpresaTabVisible}"
                        VerticalOptions="End" />
                </Grid>

                <!--  Tab 2: Global  -->
                <Grid x:Name="tabHeader2" Grid.Column="2">
                    <Grid.Behaviors>
                        <toolkit:TouchBehavior
                            DefaultOpacity="1"
                            PressedAnimationDuration="100"
                            PressedOpacity="0.6" />
                    </Grid.Behaviors>
                    <Grid.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding GlobalCommand}" />
                    </Grid.GestureRecognizers>
                    <Label
                        x:Name="tabLabel2"
                        FontSize="11"
                        HorizontalTextAlignment="Center"
                        Opacity="0.55"
                        Text="Global"
                        TextColor="White"
                        VerticalTextAlignment="Center" />
                    <BoxView
                        HeightRequest="3"
                        Color="White"
                        HorizontalOptions="Fill"
                        IsVisible="{Binding IsGlobalTabVisible}"
                        VerticalOptions="End" />
                </Grid>
            </Grid>

            <!--  Conteúdo das abas — sobrepostos no mesmo Grid.Cell, IsVisible controla qual exibe  -->
            <Grid Grid.Row="1">

                <!--  Meus Resultados — sempre carregado (aba inicial)  -->
                <controls:DashboardTabMeusResultados x:Name="tabContent0" />

                <!--  Empresa — carregado na primeira visita  -->
                <controls:DashboardTabEmpresa x:Name="tabContent1" IsVisible="False" Opacity="0" />

                <!--  Global — carregado na primeira visita  -->
                <controls:DashboardTabGlobal x:Name="tabContent2" IsVisible="False" Opacity="0" />
            </Grid>
        </Grid>

        <listView:SfListView
            Grid.Row="2"
            Padding="10,0"
            AutoFitMode="Height"
            Background="White"
            CachingStrategy="RecycleTemplate"
            ItemSpacing="0"
            ItemsSource="{Binding LotesEmAlerta}"
            ItemsSourceChangeCachingStrategy="RecycleItems"
            SelectionMode="None">

            <listView:SfListView.HeaderTemplate>
                <DataTemplate>
                    <Label
                        FontAttributes="Bold"
                        FontSize="Medium"
                        Text="{localization:Translate LotesEmAlerta}"
                        TextColor="{StaticResource PrimaryColor}"
                        VerticalOptions="Center" />
                </DataTemplate>
            </listView:SfListView.HeaderTemplate>

            <listView:SfListView.ItemTemplate>
                <DataTemplate x:DataType="models:Lote">
                    <!--★★★ SfButton com Border dentro ★★★-->
                    <buttons:SfButton
                        Margin="0,4"
                        Padding="0"
                        Background="Transparent"
                        CornerRadius="12"
                        HeightRequest="60"
                        ShowIcon="False">

                        <buttons:SfButton.Content>
                            <DataTemplate>
                                <Border
                                    x:Name="loteBorder"
                                    Margin="2,0"
                                    Padding="0"
                                    Background="{Binding BackgroundColor}"
                                    MinimumHeightRequest="50"
                                    Stroke="{Binding StatusColor}"
                                    StrokeThickness="1">

                                    <Border.Behaviors>
                                        <toolkit:TouchBehavior
                                            DefaultOpacity="1"
                                            DefaultScale="1"
                                            PressedAnimationDuration="100"
                                            PressedOpacity="0.7"
                                            PressedScale="0.95" />
                                    </Border.Behaviors>

                                    <Border.GestureRecognizers>
                                        <TapGestureRecognizer Command="{Binding Source={x:Reference dashboardView}, Path=BindingContext.VaiParaLoteCommand}" CommandParameter="{Binding .}" />
                                    </Border.GestureRecognizers>

                                    <Grid
                                        Padding="10"
                                        ColumnDefinitions="80,Auto,*,45"
                                        RowDefinitions="Auto"
                                        VerticalOptions="Center">
                                        <Label
                                            Grid.Column="0"
                                            FontSize="Micro"
                                            HorizontalTextAlignment="Center"
                                            Text="{Binding numero}"
                                            TextColor="{StaticResource PrimaryColor}"
                                            VerticalTextAlignment="Center" />
                                        <Label
                                            Grid.Column="1"
                                            FontSize="Micro"
                                            HorizontalTextAlignment="Center"
                                            Text="{Binding dataInicio, StringFormat='{0:dd/MM/yy}'}"
                                            VerticalTextAlignment="Center" />
                                        <Label
                                            Grid.Column="2"
                                            FontSize="Micro"
                                            HorizontalTextAlignment="Center"
                                            LineBreakMode="TailTruncation"
                                            Text="{Binding UnidadeEpidemiologicaNome}"
                                            VerticalTextAlignment="Center" />
                                        <Label
                                            Grid.Column="3"
                                            FontAttributes="Bold"
                                            FontSize="Medium"
                                            HorizontalTextAlignment="Center"
                                            Text="{Binding ISIMacroScoreMedio, StringFormat='{0:N1}'}"
                                            TextColor="{Binding StatusColor}"
                                            VerticalTextAlignment="Center" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </buttons:SfButton.Content>
                    </buttons:SfButton>
                </DataTemplate>
            </listView:SfListView.ItemTemplate>


            <!--Empty View-->

            <listView:SfListView.EmptyView>
                <Border
                    Padding="20,16"
                    Background="White"
                    Stroke="#E0E0E0"
                    StrokeDashArray="4,4"
                    StrokeShape="RoundRectangle 16"
                    StrokeThickness="2"
                    VerticalOptions="Center">
                    <VerticalStackLayout
                        Background="White"
                        HorizontalOptions="Center"
                        VerticalOptions="Fill">
                        <Label
                            Grid.Row="0"
                            FontFamily="FontAwesomeSolid"
                            FontSize="32"
                            HorizontalTextAlignment="Center"
                            Opacity="0.3"
                            Text="{x:Static fontawesome:FontAwesomeIcons.Check}"
                            TextColor="#4CAF50"
                            VerticalTextAlignment="Center" />
                        <Label
                            Grid.Row="1"
                            FontSize="14"
                            HorizontalTextAlignment="Center"
                            Text="Nenhum lote em alerta"
                            TextColor="#757575"
                            VerticalOptions="Center" />
                    </VerticalStackLayout>
                </Border>
            </listView:SfListView.EmptyView>
        </listView:SfListView>
    </Grid>
</ContentView>