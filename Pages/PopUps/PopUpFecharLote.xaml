<?xml version="1.0" encoding="UTF-8" ?>
<toolkit:Popup
    x:Class="SilvaData.Pages.PopUps.PopUpFecharLote"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
    xmlns:local="clr-namespace:SilvaData.Pages.PopUps"
    xmlns:localization="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui"
    xmlns:models="clr-namespace:SilvaData.Models"
    xmlns:sys="clr-namespace:System;assembly=netstandard"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    x:TypeArguments="models:LoteFechamentoInfo"
    Background="Transparent"
    CanBeDismissedByTappingOutsideOfPopup="False"
    VerticalOptions="Center">
    <Border
        Margin="20"
        Padding="10"
        BackgroundColor="{StaticResource White}"
        HorizontalOptions="Fill"
        Stroke="{StaticResource Primary}"
        StrokeShape="RoundRectangle 10"
        StrokeThickness="1"
        VerticalOptions="Center">
        <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10">
            <Label
                FontAttributes="Bold"
                FontSize="18"
                HorizontalOptions="Center"
                Text="{Binding Titulo}" />

            <StackLayout
                Grid.Row="1"
                Spacing="15"
                VerticalOptions="Center">
                <Label
                    HorizontalOptions="Center"
                    HorizontalTextAlignment="Center"
                    Text="{Binding Mensagem}"
                    VerticalOptions="Center" />

                <StackLayout HorizontalOptions="Center" Orientation="Horizontal">
                    <Label Text="{localization:Translate DataFechamento}" VerticalOptions="Center" />
                    <DatePicker Date="{Binding DataFechamento}" Format="dd/MM/yyyy" />
                </StackLayout>

                <StackLayout>
                    <Label Text="{localization:Translate Observacoes}" />
                    <Editor HeightRequest="100" Text="{Binding Observacoes}" />
                </StackLayout>
            </StackLayout>

            <Grid
                Grid.Row="2"
                ColumnDefinitions="*,*"
                ColumnSpacing="10">
                <buttons:SfButton
                    Command="{Binding ConfirmarCommand}"
                    Style="{StaticResource ButtonPrimary}"
                    Text="{localization:Translate Confirmar}" />
                <buttons:SfButton
                    Grid.Column="1"
                    Command="{Binding CancelarCommand}"
                    Style="{StaticResource ButtonSecondary}"
                    Text="{localization:Translate Cancelar}" />
            </Grid>
        </Grid>
    </Border>
</toolkit:Popup>
