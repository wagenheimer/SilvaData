<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="SilvaData.Controls.SincronizacaoView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:conv="clr-namespace:SilvaData.Converters"
    xmlns:localization="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
    xmlns:fontawesome="clr-namespace:SilvaData.Utils"
    x:DataType="viewmodels:SincronizacaoViewModel"
    BackgroundColor="#F5F5F5">
    <ContentView.Resources>
        <conv:PercentToFractionConverter x:Key="PercentToFractionConverter" />
        <conv:IsNotZeroConverter x:Key="IsNotZeroConverter" />
        <conv:InvertBoolConverter x:Key="InvertBoolConverter" />
    </ContentView.Resources>

    <Grid RowDefinitions="Auto,*" BackgroundColor="{StaticResource QuaseBranco}">
        <!-- ── Header logo (padrão global) ── -->
        <Grid Grid.Row="0" Padding="20,16,20,16">
            <Grid.Background>
                <LinearGradientBrush EndPoint="0,1">
                    <GradientStop Offset="0.0" Color="{StaticResource PrimaryLightColor}" />
                    <GradientStop Offset="1.0" Color="{StaticResource QuaseBranco}" />
                </LinearGradientBrush>
            </Grid.Background>
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" VerticalOptions="Center">
                <Image
                    Grid.Column="0"
                    HeightRequest="44"
                    WidthRequest="44"
                    Aspect="AspectFit"
                    Source="silvadatalogo" />
                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        Text="Silvadata"
                        TextColor="{StaticResource SecondaryColor}" />
                    <Label
                        FontSize="12"
                        Text="from Silvateam"
                        TextColor="{StaticResource Gray400}" />
                </VerticalStackLayout>
            </Grid>
        </Grid>

        <VerticalStackLayout
            Grid.Row="1"
            Margin="10"
            Spacing="16"
            VerticalOptions="Center"
            IsVisible="{Binding SincronizacaoComSucesso, Converter={StaticResource InvertBoolConverter}}">
            <Label
                FontSize="24"
                FontAttributes="Bold"
                HorizontalTextAlignment="Center"
                Text="{localization:Translate SincronizacaoDeDados}"
                TextColor="{StaticResource PrimaryColor}" />

            <Border
                Padding="24"
                Background="White"
                StrokeShape="RoundRectangle 16"
                StrokeThickness="0"
                VerticalOptions="Center">
                <VerticalStackLayout Spacing="20">
                    <Grid ColumnDefinitions="Auto,*">
                        <Border
                            Grid.Column="0"
                            Background="{StaticResource PrimaryColor}"
                            IsVisible="{Binding IndicadorVisivel}"
                            StrokeShape="RoundRectangle 30">
                            <ActivityIndicator
                                HeightRequest="24"
                                IsRunning="True"
                                WidthRequest="24"
                                Color="White" />
                        </Border>
                        <VerticalStackLayout
                            Grid.Column="1"
                            Padding="8,0"
                            Spacing="2">
                            <Label
                                FontAttributes="Bold"
                                FontSize="Small"
                                LineBreakMode="WordWrap"
                                Text="{Binding EtapaAtual}"
                                TextColor="#212121" />
                            <!--  Descrição da sub-tarefa  -->
                            <Label
                                FontSize="11"
                                IsVisible="{Binding SubTexto, Converter={StaticResource IsNotNullOrEmptyConverter}}"
                                LineBreakMode="WordWrap"
                                Opacity="0.65"
                                Text="{Binding SubTexto}"
                                TextColor="#424242" />
                        </VerticalStackLayout>
                    </Grid>
                    <!--  Progresso principal  -->
                    <VerticalStackLayout Spacing="8">
                        <HorizontalStackLayout HorizontalOptions="Fill">
                            <Label
                                FontSize="13"
                                Text="{localization:Translate Progresso}"
                                TextColor="#757575" />
                            <Label
                                Padding="5,0"
                                FontAttributes="Bold"
                                FontSize="14"
                                HorizontalOptions="End"
                                Text="{Binding Progresso}"
                                TextColor="{StaticResource PrimaryColor}" />
                        </HorizontalStackLayout>
                        <ProgressBar HeightRequest="10" Progress="{Binding Percent, Converter={StaticResource PercentToFractionConverter}}" />
                    </VerticalStackLayout>
                    <!--  Sub-progresso: reserva espaço fixo para evitar layout shift  -->
                    <VerticalStackLayout
                        MinimumHeightRequest="36"
                        Opacity="{Binding SubPercent, Converter={StaticResource IsNotZeroConverter}}"
                        Spacing="4">
                        <HorizontalStackLayout HorizontalOptions="FillAndExpand">
                            <Label
                                Padding="0,0,4,0"
                                FontSize="12"
                                Opacity="0.7"
                                Text="{localization:Translate SubTarefa}"
                                TextColor="#757575" />
                            <Label
                                FontSize="12"
                                HorizontalOptions="FillAndExpand"
                                IsVisible="{Binding Texto2, Converter={StaticResource IsNotNullOrEmptyConverter}}"
                                LineBreakMode="TailTruncation"
                                Text="{Binding Texto2}"
                                TextColor="{StaticResource PrimaryColor}" />
                        </HorizontalStackLayout>
                        <ProgressBar HeightRequest="6" Progress="{Binding SubPercent, Converter={StaticResource PercentToFractionConverter}}" />
                    </VerticalStackLayout>
                    <!--  Tempo Decorrido  -->
                    <Border
                        Padding="12,10"
                        Background="#F1F8E9"
                        StrokeShape="RoundRectangle 10">
                        <VerticalStackLayout Spacing="4">
                            <Label
                                FontSize="11"
                                Text="{localization:Translate TempoDecorrido}"
                                TextColor="{StaticResource SecondaryColor}" />
                            <Label
                                FontAttributes="Bold"
                                FontSize="14"
                                Text="{Binding TempoDecorrido}"
                                TextColor="{StaticResource PrimaryColor}" />
                        </VerticalStackLayout>
                    </Border>

                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>

        <!--  Success View UI  -->
        <VerticalStackLayout
            x:Name="SuccessView"
            Grid.Row="1"
            Padding="30"
            IsVisible="{Binding SincronizacaoComSucesso}"
            Spacing="24"
            VerticalOptions="Center">

            <Border
                Padding="30"
                BackgroundColor="White"
                HorizontalOptions="Center"
                StrokeShape="RoundRectangle 24"
                StrokeThickness="0">
                <Border.Shadow>
                    <Shadow
                        Brush="Black"
                        Opacity="0.1"
                        Offset="0,10"
                        Radius="20" />
                </Border.Shadow>
                <VerticalStackLayout Spacing="20">
                    <Label
                        FontFamily="FASolid"
                        FontSize="80"
                        HorizontalOptions="Center"
                        Text="&#xf058;"
                        TextColor="#07AD53" />

                    <VerticalStackLayout Spacing="8">
                        <Label
                            FontAttributes="Bold"
                            FontSize="24"
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            Text="{localization:Translate Sucesso}"
                            TextColor="{StaticResource PrimaryColor}" />
                        <Label
                            FontSize="16"
                            HorizontalOptions="Center"
                            HorizontalTextAlignment="Center"
                            Opacity="0.7"
                            Text="{localization:Translate DadosRecebidosComSucesso}"
                            TextColor="{StaticResource SecondaryColor}" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <buttons:SfButton
                Command="{Binding FinalizarSincronizacaoCommand}"
                CornerRadius="25"
                FontSize="18"
                HeightRequest="50"
                HorizontalOptions="Center"
                Text="OK"
                WidthRequest="200" />
        </VerticalStackLayout>

    </Grid>
</ContentView>
