<?xml version="1.0" encoding="UTF-8" ?>
<ContentView
    x:Class="SilvaData.Controls.LoteView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
    xmlns:controls="clr-namespace:SilvaData.Controls"
    xmlns:fontawesome="clr-namespace:SilvaData.FontAwesome"
    xmlns:listview="clr-namespace:Syncfusion.Maui.ListView;assembly=Syncfusion.Maui.ListView"
    xmlns:localization="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui"
    xmlns:models="clr-namespace:SilvaData.Models"
    xmlns:sfComboBox="clr-namespace:Syncfusion.Maui.Inputs;assembly=Syncfusion.Maui.Inputs"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:viewmodels="clr-namespace:SilvaData.ViewModels"
    x:Name="loteViewPage"
    x:DataType="viewmodels:LoteViewModel">

    <Grid RowDefinitions="Auto,*" RowSpacing="0">

        <Grid
            Grid.Row="0"
            Margin="0"
            RowDefinitions="Auto,Auto"
            RowSpacing="0">

            <!-- ── Header logo (padrão global) ── -->
            <Grid Grid.Row="0" Padding="20,16,20,16">
                <Grid.Background>
                    <LinearGradientBrush EndPoint="0,1">
                        <GradientStop Offset="0.0" Color="{StaticResource PrimaryLightColor}" />
                        <GradientStop Offset="1.0" Color="{StaticResource QuaseBranco}" />
                    </LinearGradientBrush>
                </Grid.Background>
                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12" VerticalOptions="Center">
                    <Image
                        Grid.Column="0"
                        HeightRequest="44"
                        WidthRequest="44"
                        Aspect="AspectFit"
                        Source="silvadatalogo" />
                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                        <Label
                            FontAttributes="Bold"
                            FontSize="18"
                            Text="Silvadata"
                            TextColor="{StaticResource SecondaryColor}" />
                        <Label
                            FontSize="12"
                            Text="from Silvateam"
                            TextColor="{StaticResource Gray400}" />
                    </VerticalStackLayout>
                    <HorizontalStackLayout Grid.Column="2" Spacing="6" VerticalOptions="Center">
                        <Label
                            FontAttributes="Bold"
                            FontSize="15"
                            HorizontalTextAlignment="End"
                            TextColor="{StaticResource PrimaryColor}"
                            VerticalOptions="Center">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="{Binding Title}" TextColor="{StaticResource PrimaryColor}"/>
                                    <Span Text=" (" TextColor="{StaticResource PrimaryColor}" />
                                    <Span Text="{Binding ListaLotes.Count}" TextColor="{StaticResource PrimaryColor}"/>
                                    <Span Text=")" TextColor="{StaticResource PrimaryColor}"/>
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <buttons:SfButton
                            Background="Transparent"
                            Command="{Binding ShowHidePesquisaCommand}"
                            FontFamily="FontAwesomeLight"
                            FontSize="Small"
                            HasShadow="False"
                            ShowIcon="False"
                            Text="{x:Static fontawesome:FontAwesomeIcons.Down}"
                            TextColor="{StaticResource PrimaryColor}"
                            VerticalOptions="Center"
                            WidthRequest="36" />
                    </HorizontalStackLayout>
                </Grid>
            </Grid>

            <!-- ── Painel de filtros (colapsável) ── -->
            <Grid
                Grid.Row="1"
                Padding="10,0,10,0"
                IsVisible="{Binding PesquisaVisible}"
                RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                <Grid.Background>
                    <LinearGradientBrush EndPoint="0,1">
                        <GradientStop Offset="0.1" Color="{StaticResource PrimaryColor}" />
                        <GradientStop Offset="1.0" Color="{StaticResource SecondaryColor}" />
                    </LinearGradientBrush>
                </Grid.Background>

                <!--  Pesquisar Lote  -->
                <StackLayout Grid.Row="0" Padding="2">
                    <Label
                        Margin="0"
                        Padding="0"
                        FontSize="Micro"
                        Text="{localization:Translate PesquisarLotes}"
                        TextColor="White" />
                    <Border
                        Margin="0"
                        Padding="5,0"
                        Background="White"
                        HeightRequest="50"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="0">
                        <Entry
                            x:Name="PesquisaEntry"
                            Background="White"
                            SelectionColor="{StaticResource PrimaryColor}"
                            Text="{Binding PesquisaLoteText, Mode=TwoWay}"
                            TextColor="{StaticResource SecondaryColor}" />
                    </Border>
                </StackLayout>

                <!-- Unidade Epidemiológica (Galpão) -->
                <StackLayout Grid.Row="1" Padding="2">
                    <Label
                        Margin="0"
                        Padding="5,0"
                        FontSize="Micro"
                        Text="{localization:Translate UnidadeEpidemiológica}"
                        TextColor="White" />
                    <Border
                        Margin="0"
                        Padding="5,0"
                        Background="White"
                        HeightRequest="50"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="0">
                        <sfComboBox:SfComboBox
                            x:Name="unidadeEpidemiologicaCombobox"
                            Margin="0"
                            Background="White"
                            DisplayMemberPath="nome"
                            IsEditable="True"
                            ItemsSource="{Binding UEList}"
                            SelectionColor="{StaticResource PrimaryColor}"
                            SelectedItem="{Binding SelectedFiltroUE, Mode=TwoWay}" />
                    </Border>
                </StackLayout>



                <!--  Botões  -->
                <Grid
                    Grid.Row="3"
                    Margin="10,5"
                    ColumnDefinitions="100,*,60"
                    ColumnSpacing="10"
                    IsVisible="{Binding PesquisaVisible}"
                    RowDefinitions="50">

                    <!--  Ordem  -->
                    <buttons:SfButton
                        Grid.Column="0"
                        Command="{Binding InverteOrdemLotesCommand}"
                        HorizontalOptions="Fill"
                        Style="{StaticResource IconTopButtonStyle}"
                        TextColor="White"
                        WidthRequest="-1">
                        <buttons:SfButton.Content>
                            <DataTemplate>
                                <HorizontalStackLayout Margin="10,5" Spacing="5">
                                    <Label
                                        Grid.Column="0"
                                        FontFamily="FontAwesomeSolid"
                                        Text="{Binding OrdemLotesIcone}"
                                        TextColor="White"
                                        VerticalOptions="Center" />
                                    <Label
                                        Grid.Column="1"
                                        FontSize="Small"
                                        Text="{localization:Translate OrdemDosLotes}"
                                        TextColor="White"
                                        VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </buttons:SfButton.Content>
                    </buttons:SfButton>

                    <!--  Limpar Filtros  -->
                    <buttons:SfButton
                        Grid.Column="1"
                        Background="{StaticResource CorBotao}"
                        Command="{Binding LimparFiltrosCommand}"
                        HorizontalOptions="Fill"
                        Style="{StaticResource IconTopButtonStyle}"
                        WidthRequest="-1">
                        <buttons:SfButton.Content>
                            <DataTemplate>
                                <HorizontalStackLayout
                                    Margin="10,5"
                                    HorizontalOptions="Center"
                                    Spacing="5">
                                    <Label
                                        FontFamily="FontAwesomeSolid"
                                        Text="{x:Static fontawesome:FontAwesomeIcons.Recycle}"
                                        TextColor="White"
                                        VerticalOptions="Center" />
                                    <Label
                                        FontSize="Small"
                                        HorizontalTextAlignment="Center"
                                        Text="{localization:Translate LimparFiltros}"
                                        TextColor="White"
                                        VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </buttons:SfButton.Content>
                    </buttons:SfButton>

                    <!--  Show/Hide  -->
                    <buttons:SfButton
                        Grid.Column="2"
                        Padding="2"
                        Background="{StaticResource CorBotao}"
                        Command="{Binding ShowHidePesquisaCommand}"
                        FontFamily="FontAwesomeLight"
                        FontSize="Small"
                        Style="{StaticResource IconTopButtonStyle}"
                        Text="{x:Static fontawesome:FontAwesomeIcons.Up}"
                        TextColor="White"
                        VerticalOptions="Center" />

                </Grid>

                <!--  Título Lotes  -->
                <Grid
                    Grid.Row="4"
                    Margin="10,5,10,0"
                    Padding="10,5"
                    ColumnDefinitions="*,80,100">
                    <Label
                        Grid.Column="0"
                        FontSize="14"
                        FontAttributes="Bold"
                        Text="{localization:Translate UnidadeEpidemiológica}"
                        TextColor="{StaticResource PrimaryColor}"
                        VerticalOptions="Center" />
                    <Label
                        Grid.Column="1"
                        FontSize="14"
                        FontAttributes="Bold"
                        HorizontalTextAlignment="Center"
                        Text="{localization:Translate Lote}"
                        TextColor="{StaticResource PrimaryColor}"
                        VerticalOptions="Center" />
                    <Label
                        Grid.Column="2"
                        FontSize="14"
                        FontAttributes="Bold"
                        HorizontalTextAlignment="End"
                        Text="{localization:Translate Alojamento}"
                        TextColor="{StaticResource PrimaryColor}"
                        VerticalOptions="Center" />
                    <BoxView Grid.Row="0" Grid.ColumnSpan="3" HeightRequest="1" Color="{StaticResource PrimaryColor}" VerticalOptions="End" Margin="0,5,0,-5" />
                </Grid>

            </Grid>


        </Grid>

        <Grid
            Grid.Row="1"
            Padding="0"
            RowDefinitions="*">
            <listview:SfListView
                x:Name="sfListView"
                Grid.Row="0"
                Margin="0,2"
                Padding="3,0"
                IsVisible="{Binding IsBusy, Converter={StaticResource InvertBoolean}}"
                ItemSize="50"
                ItemSpacing="2"
                ItemTapped="OnLoteItemTapped"
                ItemsSource="{Binding ListaLotes}"
                SelectionBackground="#330888CD"
                SelectionMode="Single">

                <listview:SfListView.EmptyView>
                    <VerticalStackLayout
                        Padding="30,60"
                        Spacing="16"
                        VerticalOptions="Center">

                        <Border
                            Padding="24"
                            Background="#F0F4F8"
                            HorizontalOptions="Center"
                            StrokeShape="RoundRectangle 50"
                            StrokeThickness="0">
                            <Label
                                FontFamily="FontAwesomeSolid"
                                FontSize="56"
                                HorizontalTextAlignment="Center"
                                Opacity="0.4"
                                Text="{x:Static fontawesome:FontAwesomeIcons.ClipboardList}"
                                TextColor="{StaticResource PrimaryColor}" />
                        </Border>

                        <VerticalStackLayout Spacing="6">
                            <Label
                                FontAttributes="Bold"
                                FontSize="18"
                                HorizontalTextAlignment="Center"
                                Text="{localization:Translate NenhumLoteTratamento}"
                                TextColor="{StaticResource PrimaryColor}" />
                            <Label
                                FontSize="13"
                                HorizontalTextAlignment="Center"
                                Opacity="0.7"
                                Text="{localization:Translate AltereCriteriosOuAdicioneNovoLote}"
                                TextColor="{StaticResource SecondaryColor}" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </listview:SfListView.EmptyView>

                <listview:SfListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Lote">
                        <Grid Padding="10,12" RowDefinitions="Auto,1">
                            <Grid Grid.Row="0" ColumnDefinitions="*,80,100">
                                <Label
                                    Grid.Column="0"
                                    FontSize="14"
                                    Text="{Binding UnidadeEpidemiologicaNome}"
                                    TextColor="{StaticResource DarkColor}"
                                    VerticalOptions="Center" />
                                <Label
                                    Grid.Column="1"
                                    FontSize="14"
                                    HorizontalTextAlignment="Center"
                                    Text="{Binding numero}"
                                    TextColor="{StaticResource DarkColor}"
                                    VerticalOptions="Center" />
                                <Label
                                    Grid.Column="2"
                                    FontSize="14"
                                    HorizontalTextAlignment="End"
                                    Text="{Binding dataInicio, StringFormat='{0:dd/MM/yyyy}'}"
                                    TextColor="{StaticResource DarkColor}"
                                    VerticalOptions="Center" />
                            </Grid>
                            <BoxView Grid.Row="1" HeightRequest="1" Color="{StaticResource Gray200}" Margin="15,12,15,0" />
                        </Grid>
                    </DataTemplate>
                </listview:SfListView.ItemTemplate>
            </listview:SfListView>

            <controls:LoadingView
                x:Name="busyindicator"
                Grid.Row="0"
                Margin="0,0"
                Padding="0"
                Background="#220888CD"
                HorizontalOptions="Fill"
                IsVisible="{Binding IsBusy}"
                Text="{localization:Translate Aguarde}"
                VerticalOptions="Fill" />
        </Grid>

        <buttons:SfButton
            Grid.Row="1"
            Command="{Binding NovoLoteCommand}"
            IsVisible="{Binding IsNovoLoteVisible}"
            Style="{StaticResource CircleButtonPlus}"
            VerticalOptions="End" />
    </Grid>

</ContentView>
