<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SilvaData.Pages.LoteViews.AvaliacaoGalpaoFormView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
    xmlns:controls="clr-namespace:SilvaData.Controls"
    xmlns:listView="clr-namespace:Syncfusion.Maui.ListView;assembly=Syncfusion.Maui.ListView"
    xmlns:localization="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui" xmlns:safe="http://isisis.com.br/safe"
    xmlns:shimmer="clr-namespace:Syncfusion.Maui.Shimmer;assembly=Syncfusion.Maui.Core"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:viewModels="clr-namespace:SilvaData.ViewModels"
    x:DataType="viewModels:AvaliacaoGalpaoFormViewModel"
    Background="{StaticResource PrimaryColor}">

    <ContentPage.Resources>
        <ResourceDictionary>
            <DataTemplate x:Key="GalpaoFooterTemplate">
                <controls:GalpaoFormFooter />
            </DataTemplate>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.Behaviors>
        <toolkit:StatusBarBehavior StatusBarColor="{StaticResource PrimaryColor}" StatusBarStyle="LightContent" />
    </ContentPage.Behaviors>

    <Grid
        Background="{StaticResource QuaseBranco}"
        RowDefinitions="Auto,Auto,*,Auto"
        RowSpacing="0">

        <!--  Cabeçalho com título, subtítulo e botão Voltar  -->
        <controls:LoteFormTopHeader Grid.Row="0" />

        <!--  Painel de estatísticas (Quantitativo ou Qualitativo)  -->
        <VerticalStackLayout Grid.Row="1">

            <!--  Quantitativo: Mínimo / Realizado / Máximo / Média  -->
            <Grid
                Background="{StaticResource SecondaryColor}"
                IsVisible="{Binding AvaliacaoGalpaoQuantitativo}"
                RowDefinitions="40,80">
                <BoxView Grid.Row="0" Background="{StaticResource SecondaryColor}" />
                <BoxView Grid.Row="1" Background="{StaticResource QuaseBranco}" />

                <Border
                    Grid.Row="1"
                    Margin="5,0"
                    Padding="0"
                    Background="White"
                    StrokeShape="RoundRectangle 20"
                    TranslationY="-40">
                    <Grid
                        Padding="15,0,0,0"
                        ColumnDefinitions="*,*,*,*"
                        RowDefinitions="Auto,Auto"
                        RowSpacing="0"
                        VerticalOptions="Center">
                        <Label Grid.Column="0" FontSize="11" HorizontalTextAlignment="Center" Text="{safe:Translate Minimo}" VerticalTextAlignment="Center" />
                        <Label Grid.Column="1" FontSize="11" HorizontalTextAlignment="Center" Text="{safe:Translate Realizado}" VerticalTextAlignment="Center" />
                        <Label Grid.Column="2" FontSize="11" HorizontalTextAlignment="Center" Text="{safe:Translate Maximo}" VerticalTextAlignment="Center" />
                        <Label Grid.Column="3" FontSize="11" HorizontalTextAlignment="Center" Text="{safe:Translate Media}" VerticalTextAlignment="Center" />

                        <Label Grid.Row="1" Grid.Column="0" FontAttributes="Bold" HorizontalTextAlignment="Center" Text="{Binding ParametroSelecionado.qtdMinima}" TextColor="{StaticResource PrimaryColor}" VerticalTextAlignment="Center" />
                        <Label Grid.Row="1" Grid.Column="1" FontAttributes="Bold" HorizontalTextAlignment="Center" Text="{Binding LoteFormulario.AvaliacoesRealizadasQuantitativa}" TextColor="{Binding RealizadoColor}" VerticalTextAlignment="Center" />
                        <Label Grid.Row="1" Grid.Column="2" FontAttributes="Bold" HorizontalTextAlignment="Center" Text="{Binding ParametroSelecionado.qtdCampos}" TextColor="{StaticResource PrimaryColor}" VerticalTextAlignment="Center" />
                        <Label Grid.Row="1" Grid.Column="3" FontAttributes="Bold" HorizontalTextAlignment="Center" Text="{Binding LoteFormulario.AvaliacaoMediaQuantitativa, StringFormat='{0:F2}'}" TextColor="{StaticResource PrimaryColor}" VerticalTextAlignment="Center" />
                    </Grid>
                </Border>
            </Grid>

            <!--  Qualitativo: Mínimo / Realizado / Máximo  -->
            <Grid
                Background="{StaticResource SecondaryColor}"
                IsVisible="{Binding AvaliacaoGalpaoQualitativo}"
                RowDefinitions="40,80">
                <BoxView Grid.Row="0" Background="{StaticResource SecondaryColor}" />
                <BoxView Grid.Row="1" Background="{StaticResource QuaseBranco}" />

                <Border
                    Grid.Row="1"
                    Margin="5,0"
                    Padding="0"
                    Background="White"
                    StrokeShape="RoundRectangle 20"
                    TranslationY="-40">
                    <Grid
                        Padding="15,0,0,0"
                        ColumnDefinitions="*,*,*"
                        RowDefinitions="Auto,Auto"
                        RowSpacing="0"
                        VerticalOptions="Center">
                        <Label Grid.Column="0" FontSize="11" HorizontalTextAlignment="Center" Text="{safe:Translate Minimo}" VerticalTextAlignment="Center" />
                        <Label Grid.Column="1" FontSize="11" HorizontalTextAlignment="Center" Text="{safe:Translate Realizado}" VerticalTextAlignment="Center" />
                        <Label Grid.Column="2" FontSize="11" HorizontalTextAlignment="Center" Text="{safe:Translate Maximo}" VerticalTextAlignment="Center" />

                        <Label Grid.Row="1" Grid.Column="0" FontAttributes="Bold" HorizontalTextAlignment="Center" Text="{Binding ParametroSelecionado.qtdMinima}" TextColor="{StaticResource PrimaryColor}" VerticalTextAlignment="Center" />
                        <Label Grid.Row="1" Grid.Column="1" FontAttributes="Bold" HorizontalTextAlignment="Center" Text="{Binding LoteFormulario.AvaliacoesRealizadasQualitativa}" TextColor="{Binding RealizadoColor}" VerticalTextAlignment="Center" />
                        <Label Grid.Row="1" Grid.Column="2" FontAttributes="Bold" HorizontalTextAlignment="Center" Text="{Binding ParametroSelecionado.qtdCampos}" TextColor="{StaticResource PrimaryColor}" VerticalTextAlignment="Center" />
                    </Grid>
                </Border>
            </Grid>

        </VerticalStackLayout>

        <!--  Conteúdo principal: Quantitativo (lista) ou Qualitativo (alternativas)  -->

        <listView:SfListView
            x:Name="camposaPreencherGalpao"
            Grid.Row="2"
            IsStickyFooter="False"
            IsVisible="{Binding AvaliacaoGalpaoQuantitativo}"
            ItemTemplate="{StaticResource Quantitativo}"
            ItemsSource="{Binding LoteFormulario.ListaAvaliacoesGalpao}"
            SelectionMode="None">
            <listView:SfListView.ItemsLayout>
                <listView:GridLayout SpanCount="2" />
            </listView:SfListView.ItemsLayout>
        </listView:SfListView>

        <!--
            Qualitativo: AvaliacaoAlternativas sempre na árvore visual.
            Como ParametroSelecionado é definido ANTES do PushModalAsync,
            AvaliacaoGalpaoQualitativo já é verdadeiro no primeiro render —
            o controle recebe os dados imediatamente, sem precisar de segunda entrada.
        -->
        <ScrollView
            Grid.Row="2"
            IsVisible="{Binding AvaliacaoGalpaoQualitativo}"
            TranslationY="-30">
            <VerticalStackLayout>

                <!--  Data da avaliação (inline — não usa LoteFormHeader por incompatibilidade de ViewModel)  -->
                <controls:ISIDatePicker
                    Margin="4,1,10,4"
                    Padding="0"
                    Data="{Binding LoteFormulario.LoteForm.data, Mode=TwoWay}"
                    Hint="{safe:Translate Data}"
                    IsReadOnly="{Binding ReadOnly, Mode=OneWay}"
                    MinimumHeightRequest="55" />

                <controls:AvaliacaoAlternativas x:Name="avaliacaoAlternativas" />

                <!--  Observações  -->
                <Label
                    Margin="10,10,10,4"
                    Text="{safe:Translate Observações}"
                    TextColor="{StaticResource PrimaryColor}" />
                <Editor
                    Margin="10,0,10,10"
                    HeightRequest="150"
                    IsReadOnly="{Binding ReadOnly}"
                    Text="{Binding LoteFormulario.LoteForm.observacoes, Mode=TwoWay}" />

                <!--  Fotos  -->
                <Label
                    Margin="10,10,10,4"
                    Text="{safe:Translate Fotos}"
                    TextColor="{StaticResource PrimaryColor}" />
                <Grid
                    Margin="10,0,10,10"
                    ColumnDefinitions="1*,1*,1*"
                    RowDefinitions="150">
                    <controls:ImagemSelecao
                        Grid.Column="0"
                        IsReadOnly="{Binding ReadOnly, Mode=OneWay}"
                        LoteFormImagem="{Binding LoteFormImagem1, Mode=TwoWay}"
                        NumeroFoto="1" />
                    <controls:ImagemSelecao
                        Grid.Column="1"
                        IsReadOnly="{Binding ReadOnly, Mode=OneWay}"
                        LoteFormImagem="{Binding LoteFormImagem2, Mode=TwoWay}"
                        NumeroFoto="2" />
                    <controls:ImagemSelecao
                        Grid.Column="2"
                        IsReadOnly="{Binding ReadOnly, Mode=OneWay}"
                        LoteFormImagem="{Binding LoteFormImagem3, Mode=TwoWay}"
                        NumeroFoto="3" />
                </Grid>

            </VerticalStackLayout>
        </ScrollView>

        <!--  Botões de ação  -->
        <Grid Grid.Row="3" Padding="5,0" ColumnDefinitions="*,Auto" RowDefinitions="60">

            <buttons:SfButton
                x:Name="btSalvar"
                Grid.Row="0"
                Margin="4"
                Command="{Binding SalvarCommand}"
                CornerRadius="10"
                IsVisible="{Binding ReadOnly, Converter={StaticResource InvertBoolean}}"
                Style="{StaticResource PrimaryButton}"
                Text="{safe:Translate Salvar}" />

            <buttons:SfButton
                Grid.Row="0"
                Margin="4"
                Command="{Binding EditarCommand}"
                CornerRadius="10"
                IsVisible="{Binding ReadOnly}"
                Style="{StaticResource PrimaryButton}"
                Text="{safe:Translate Editar}" />

            <buttons:SfButton
                Grid.Row="0"
                Grid.Column="1"
                Margin="4"
                Padding="10,0"
                Command="{Binding ProcurarAvaliacoesCommand}"
                CornerRadius="10"
                Style="{StaticResource PrimaryButton}"
                Text="{safe:Translate VerRegistros}" />

        </Grid>

        <!--  Loading overlays  -->
        <shimmer:SfShimmer
            Grid.Row="1"
            Grid.RowSpan="4"
            IsVisible="{Binding IsBusy}"
            RepeatCount="10"
            Type="Shopping"
            VerticalOptions="Fill" />

        <controls:LoadingView
            Grid.Row="0"
            Grid.RowSpan="4"
            IsVisible="{Binding IsBusy}"
            Text="{safe:Translate Aguarde}"
            VerticalOptions="Fill" />

    </Grid>
</ContentPage>
