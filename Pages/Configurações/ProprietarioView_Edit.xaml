<?xml version="1.0" encoding="utf-8" ?>
<controls:ContentPageEdit
    x:Class="SilvaData.Controls.ProprietarioView_Edit"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
    xmlns:controls="clr-namespace:SilvaData.Controls"
    xmlns:fontawesome="clr-namespace:SilvaData.FontAwesome"
    xmlns:localization="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui"
    xmlns:utils="clr-namespace:SilvaData.Utils"
    xmlns:viewmodels="clr-namespace:SilvaData.ViewModels"
    x:DataType="viewmodels:ProprietarioEditViewModel"
    BackgroundColor="{StaticResource PrimaryColor}"
    Shell.TabBarIsVisible="false">

    <Grid
        BackgroundColor="{StaticResource QuaseBranco}"
        RowDefinitions="Auto,*"
        VerticalOptions="Fill">

        <Grid
            Grid.Row="0"
            Margin="0,0,0,5"
            Padding="0,0,0,20"
            ColumnDefinitions="*,Auto"
            RowDefinitions="Auto,Auto">

            <Grid.Background>
                <LinearGradientBrush EndPoint="0,1">
                    <GradientStop Offset="0.1" Color="{StaticResource PrimaryColor}" />
                    <GradientStop Offset="1.0" Color="{StaticResource SecondaryColor}" />
                </LinearGradientBrush>
            </Grid.Background>

            <StackLayout
                Grid.Row="0"
                Orientation="Horizontal"
                Spacing="0">
                <Label
                    Padding="15,0"
                    FontFamily="Nunito"
                    FontSize="Large"
                    HorizontalOptions="Start"
                    Text="{Binding Title}"
                    TextColor="White"
                    VerticalOptions="Center" />
            </StackLayout>

            <StackLayout
                Grid.Row="0"
                Grid.Column="1"
                Orientation="Horizontal">
                <buttons:SfButton
                    Grid.Column="1"
                    Command="{Binding BackNowCommand}"
                    Style="{StaticResource CircleButton}"
                    Text="{x:Static fontawesome:FontAwesomeIcons.ArrowTurnDownLeft}" />
            </StackLayout>

            <Label
                Grid.Row="1"
                Padding="15,0"
                FontSize="Small"
                Text="{Binding SubTitle}"
                TextColor="White" />
        </Grid>

        <Grid
            x:Name="editdados"
            Grid.Row="1"
            Margin="4"
            RowDefinitions="*,Auto"
            VerticalOptions="Fill">

            <ScrollView x:Name="scrollView" Grid.Row="0">
                <StackLayout x:Name="camposaPreencher" Margin="5,0">

                    <controls:ISITextField
                        x:Name="nome"
                        Title="{localization:Translate Nome}"
                        IsReadOnly="{Binding ReadOnly, Mode=OneWay}"
                        Text="{Binding Proprietario.nome, Mode=TwoWay}" />

                </StackLayout>
            </ScrollView>

            <controls:ContentPageEdit_Footer x:Name="editfooter" Grid.Row="1" />
        </Grid>

        <controls:LoadingView
            Grid.Row="1"
            IsVisible="{Binding IsBusy}"
            Text="{localization:Translate Aguarde}" />
    </Grid>
</controls:ContentPageEdit>
