<?xml version="1.0" encoding="UTF-8" ?>
<ContentView
    x:Class="SilvaData.Controls.SuportePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
    xmlns:fontawesome="clr-namespace:SilvaData.FontAwesome"
    xmlns:localization="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui"
    xmlns:viewmodels="clr-namespace:SilvaData.PageModels"
    x:DataType="viewmodels:SuportePageViewModel">

    <ScrollView>
        <Grid BackgroundColor="{StaticResource QuaseBranco}" RowDefinitions="Auto,*">

            <StackLayout Grid.Row="0" Spacing="0">
                <Label
                    Padding="15,10,0,0"
                    FontFamily="Nunito"
                    FontSize="Large"
                    HorizontalOptions="Start"
                    Text="{localization:Translate Suporte}"
                    TextColor="{StaticResource PrimaryColor}" />

                <Image
                    Aspect="AspectFit"
                    HeightRequest="100"
                    Source="isilogo.png" />

                <Label
                    FontSize="Micro"
                    HorizontalTextAlignment="Center"
                    Text="ISI APP ⬤ FROM"
                    TextColor="Gray" />
                <Label
                    FontAttributes="Bold"
                    HorizontalTextAlignment="Center"
                    Text="ISI Sys"
                    TextColor="{StaticResource PrimaryColor}" />

                <Label
                    x:Name="labelVersion"
                    Padding="0,0,0,50"
                    FontSize="Small"
                    HorizontalTextAlignment="Center"
                    Text="{Binding VersaoApp}" />

                <StackLayout>
                    <Border
                        Margin="20,5"
                        Padding="0,10"
                        Stroke="LightGray"
                        StrokeShape="RoundRectangle 30">

                        <Grid ColumnDefinitions="80,*" HorizontalOptions="Fill">
                            <Label
                                Grid.Column="0"
                                Padding="0,0"
                                FontFamily="FontAwesomeRegular"
                                FontSize="25"
                                HorizontalOptions="Center"
                                HorizontalTextAlignment="Start"
                                Text="{x:Static fontawesome:FontAwesomeIcons.Globe}"
                                TextColor="{StaticResource SecondaryColor}"
                                VerticalOptions="Center" />

                            <StackLayout Grid.Column="1">
                                <Label
                                    FontSize="Small"
                                    HorizontalTextAlignment="Start"
                                    Text="{localization:Translate AcesseNossoSite}"
                                    TextColor="{StaticResource PrimaryColor}"
                                    VerticalOptions="Center" />
                                <Label
                                    FontSize="Small"
                                    HorizontalTextAlignment="Start"
                                    Text="http://isiinstitute.com/"
                                    TextColor="Gray"
                                    VerticalOptions="Center" />
                            </StackLayout>
                        </Grid>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SiteCommand}" />
                        </Border.GestureRecognizers>
                    </Border>

                    <Border
                        Margin="20,5"
                        Padding="0,10"
                        Stroke="LightGray"
                        StrokeShape="RoundRectangle 30">

                        <Grid ColumnDefinitions="80,*" HorizontalOptions="Fill">
                            <Label
                                Grid.Column="0"
                                Padding="0,0"
                                FontFamily="FontAwesomeRegular"
                                FontSize="25"
                                HorizontalOptions="Center"
                                HorizontalTextAlignment="Start"
                                Text="{x:Static fontawesome:FontAwesomeIcons.Envelope}"
                                TextColor="{StaticResource SecondaryColor}"
                                VerticalOptions="Center" />

                            <StackLayout Grid.Column="1">
                                <Label
                                    FontSize="Small"
                                    HorizontalTextAlignment="Start"
                                    Text="{localization:Translate NosEnvieUmEmail}"
                                    TextColor="{StaticResource PrimaryColor}"
                                    VerticalOptions="Center" />
                                <Label
                                    FontSize="Small"
                                    HorizontalTextAlignment="Start"
                                    Text="isi@isiinstitute.com"
                                    TextColor="Gray"
                                    VerticalOptions="Center" />
                            </StackLayout>
                        </Grid>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding EmailCommand}" />
                        </Border.GestureRecognizers>
                    </Border>

                    <Border
                        Margin="20,5"
                        Padding="0,10"
                        Stroke="LightGray"
                        StrokeShape="RoundRectangle 30">

                        <Grid ColumnDefinitions="80,*" HorizontalOptions="Fill">
                            <Label
                                Grid.Column="0"
                                Padding="0,0"
                                FontFamily="FontAwesomeBrands"
                                FontSize="25"
                                HorizontalOptions="Center"
                                HorizontalTextAlignment="Start"
                                Text="{x:Static fontawesome:FontAwesomeIcons.Whatsapp}"
                                TextColor="{StaticResource SecondaryColor}"
                                VerticalOptions="Center" />

                            <Label
                                Grid.Column="1"
                                FontSize="Small"
                                HorizontalTextAlignment="Start"
                                Text="{localization:Translate FaleConoscoNoWhatsApp}"
                                TextColor="{StaticResource PrimaryColor}"
                                VerticalOptions="Center" />
                        </Grid>

                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding WhatsAppCommand}" />
                        </Border.GestureRecognizers>
                    </Border>

                    <buttons:SfButton
                        Margin="20,30"
                        BackgroundColor="{StaticResource SecondaryColor}"
                        Command="{Binding EnviarBancoDadosSuporteCommand}"
                        CornerRadius="20"
                        FontAttributes="Bold"
                        FontSize="Small"
                        HeightRequest="85"
                        Style="{StaticResource sfButtonBar}"
                        Text="{localization:Translate EnviarBancoDeDadosParaSuporte}">
                        <buttons:SfButton.ImageSource>
                            <FontImageSource
                                FontFamily="FontAwesomeSolid"
                                Glyph="{x:Static fontawesome:FontAwesomeIcons.Upload}"
                                Size="30"
                                Color="White" />
                        </buttons:SfButton.ImageSource>
                    </buttons:SfButton>
                </StackLayout>
            </StackLayout>
        </Grid>
    </ScrollView>
</ContentView>
