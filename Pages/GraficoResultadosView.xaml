<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="SilvaData.Controls.GraficoResultadosView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:buttons="clr-namespace:Syncfusion.Maui.Buttons;assembly=Syncfusion.Maui.Buttons"
    xmlns:chart="clr-namespace:Syncfusion.Maui.Toolkit.Charts;assembly=Syncfusion.Maui.Toolkit"
    xmlns:controls="clr-namespace:SilvaData.Controls"
    xmlns:fontawesome="clr-namespace:SilvaData.FontAwesome"
    xmlns:localization="clr-namespace:LocalizationResourceManager.Maui;assembly=LocalizationResourceManager.Maui" xmlns:safe="http://isisis.com.br/safe"
    xmlns:models="clr-namespace:SilvaData.Models"
    xmlns:viewmodels="clr-namespace:SilvaData.ViewModels"
    x:DataType="viewmodels:GraficoResultadosViewModel"
    BackgroundColor="{StaticResource PrimaryColor}">

    <Grid BackgroundColor="{StaticResource QuaseBranco}" RowDefinitions="Auto,*,Auto">

        <Grid
            Grid.Row="0"
            Margin="0,0,0,5"
            Padding="0,0,0,0"
            ColumnDefinitions="*,Auto"
            RowDefinitions="Auto,Auto">

            <StackLayout
                Grid.Row="0"
                Orientation="Horizontal"
                Spacing="0">
                <Label
                    Padding="15,0"
                    FontFamily="Nunito"
                    FontSize="Large"
                    HorizontalOptions="Start"
                    Text="{Binding Title}"
                    TextColor="{StaticResource PrimaryColor}"
                    VerticalOptions="Center" />
            </StackLayout>

            <Grid
                Grid.Row="0"
                Grid.Column="1"
                Margin="0,0"
                ColumnDefinitions="Auto,Auto"
                VerticalOptions="Center">

                <buttons:SfButton
                    Grid.Column="0"
                    Margin="5,5,5,0"
                    Command="{Binding ChangeLandScapeModeCommand}"
                    FontFamily="FontAwesomeSolid"
                    FontSize="Large"
                    Style="{StaticResource CircleButtonWhite}"
                    Text="{x:Static fontawesome:FontAwesomeIcons.MobileScreenButton}"
                    VerticalOptions="Center" />

                <buttons:SfButton
                    Grid.Column="1"
                    Margin="5,5,5,0"
                    Command="{Binding VoltarCommand}"
                    FontFamily="FontAwesomeSolid"
                    FontSize="Large"
                    Style="{StaticResource CircleButtonWhite}"
                    Text="{x:Static fontawesome:FontAwesomeIcons.ArrowLeft}"
                    VerticalOptions="Center" />
            </Grid>
        </Grid>

        <Border
            Grid.Row="1"
            Margin="10,0"
            Padding="5,5"
            Background="White"
            StrokeShape="RoundRectangle 8"
            StrokeThickness="0">

            <Grid RowDefinitions="*,Auto,Auto">

                <Grid
                    Grid.Row="0"
                    IsVisible="{Binding ISIScoreTotalVisible}"
                    RowDefinitions="*">

                    <Grid
                        Grid.Row="0"
                        IsVisible="{Binding GraficoSuperCategoriaVisible}"
                        RowDefinitions="*">
                        <chart:SfCartesianChart
                            x:Name="chartSuperCategoria"
                            Grid.Row="0"
                            HorizontalOptions="Fill"
                            Series="{Binding SuperCategoriaSeriesCollection}"
                            VerticalOptions="Fill">

                            <chart:SfCartesianChart.XAxes>
                                <chart:CategoryAxis LabelPlacement="BetweenTicks" ShowMajorGridLines="false">
                                    <chart:CategoryAxis.MajorTickStyle>
                                        <chart:ChartAxisTickStyle TickSize="0" />
                                    </chart:CategoryAxis.MajorTickStyle>
                                </chart:CategoryAxis>
                            </chart:SfCartesianChart.XAxes>

                            <chart:SfCartesianChart.YAxes>
                                <chart:NumericalAxis
                                    IsVisible="False"
                                    Maximum="100"
                                    Minimum="0"
                                    PlotOffsetEnd="50" />
                            </chart:SfCartesianChart.YAxes>

                            <chart:SfCartesianChart.Legend>
                                <chart:ChartLegend />
                            </chart:SfCartesianChart.Legend>

                            <chart:SfCartesianChart.TooltipBehavior>
                                <chart:ChartTooltipBehavior />
                            </chart:SfCartesianChart.TooltipBehavior>

                            <chart:SfCartesianChart.ZoomPanBehavior>
                                <chart:ChartZoomPanBehavior
                                    EnablePanning="True"
                                    EnablePinchZooming="True"
                                    ZoomMode="X" />
                            </chart:SfCartesianChart.ZoomPanBehavior>
                        </chart:SfCartesianChart>
                    </Grid>

                    <Grid
                        Grid.Row="0"
                        IsVisible="{Binding GraficoCategoriaVisible}"
                        RowDefinitions="Auto,*">

                        <Grid Grid.Row="0">
                            <Label
                                FontAttributes="Bold"
                                HorizontalTextAlignment="Center"
                                Text="{Binding SuperCategoriaSelecionada}"
                                TextColor="{StaticResource PrimaryColor}"
                                VerticalTextAlignment="Center" />
                            <Grid
                                Grid.Row="0"
                                ColumnDefinitions="50"
                                VerticalOptions="Center">
                                <buttons:SfButton
                                    Padding="0"
                                    BackgroundColor="Transparent"
                                    Command="{Binding VoltaParaSuperCategoriaCommand}"
                                    FontFamily="FontAwesomeRegular"
                                    Text="{x:Static fontawesome:FontAwesomeIcons.ArrowLeft}"
                                    TextColor="{StaticResource PrimaryColor}"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Grid>

                        <chart:SfCartesianChart
                            x:Name="chartCategoria"
                            Grid.Row="1"
                            HorizontalOptions="Fill"
                            Series="{Binding CategoriaSeriesCollection}"
                            VerticalOptions="Fill">

                            <chart:SfCartesianChart.XAxes>
                                <chart:CategoryAxis LabelPlacement="BetweenTicks" ShowMajorGridLines="false" />
                            </chart:SfCartesianChart.XAxes>

                            <chart:SfCartesianChart.YAxes>
                                <chart:NumericalAxis
                                    IsVisible="False"
                                    Maximum="100"
                                    Minimum="0" />
                            </chart:SfCartesianChart.YAxes>

                            <chart:SfCartesianChart.Legend>
                                <chart:ChartLegend />
                            </chart:SfCartesianChart.Legend>

                            <chart:SfCartesianChart.TooltipBehavior>
                                <chart:ChartTooltipBehavior />
                            </chart:SfCartesianChart.TooltipBehavior>
                        </chart:SfCartesianChart>
                    </Grid>

                    <Grid
                        Grid.Row="0"
                        IsVisible="{Binding GraficoParametroVisible}"
                        RowDefinitions="Auto,*">

                        <Grid Grid.Row="0">
                            <Label
                                FontAttributes="Bold"
                                HorizontalTextAlignment="Center"
                                Text="{Binding CategoriaSelecionada}"
                                TextColor="{StaticResource PrimaryColor}"
                                VerticalTextAlignment="Center" />
                            <Grid Grid.Row="0" ColumnDefinitions="50">
                                <buttons:SfButton
                                    Padding="0"
                                    BackgroundColor="Transparent"
                                    Command="{Binding VoltaParaCategoriaCommand}"
                                    FontFamily="FontAwesomeRegular"
                                    Text="{x:Static fontawesome:FontAwesomeIcons.ArrowLeft}"
                                    TextColor="{StaticResource PrimaryColor}"
                                    VerticalOptions="Center" />
                            </Grid>
                        </Grid>

                        <chart:SfCartesianChart
                            x:Name="chartParametro"
                            Grid.Row="1"
                            HorizontalOptions="Fill"
                            Series="{Binding ParametroSeriesCollection}"
                            VerticalOptions="Fill">

                            <chart:SfCartesianChart.XAxes>
                                <chart:CategoryAxis LabelPlacement="BetweenTicks" ShowMajorGridLines="false" />
                            </chart:SfCartesianChart.XAxes>

                            <chart:SfCartesianChart.YAxes>
                                <chart:NumericalAxis
                                    IsVisible="False"
                                    Maximum="100"
                                    Minimum="0" />
                            </chart:SfCartesianChart.YAxes>

                            <chart:SfCartesianChart.Legend>
                                <chart:ChartLegend />
                            </chart:SfCartesianChart.Legend>

                            <chart:SfCartesianChart.TooltipBehavior>
                                <chart:ChartTooltipBehavior />
                            </chart:SfCartesianChart.TooltipBehavior>
                        </chart:SfCartesianChart>
                    </Grid>
                </Grid>

                <Grid
                    Grid.Row="0"
                    IsVisible="{Binding ISIDispersaoScoreVisible}"
                    RowDefinitions="*">
                    <chart:SfCartesianChart
                        x:Name="Chart"
                        Grid.Row="0"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill">

                        <chart:SfCartesianChart.TooltipBehavior>
                            <chart:ChartTooltipBehavior />
                        </chart:SfCartesianChart.TooltipBehavior>

                        <chart:SfCartesianChart.ZoomPanBehavior>
                            <chart:ChartZoomPanBehavior EnablePanning="True" EnablePinchZooming="True" />
                        </chart:SfCartesianChart.ZoomPanBehavior>

                        <chart:SfCartesianChart.XAxes>
                            <chart:DateTimeAxis
                                EdgeLabelsDrawingMode="Shift"
                                Interval="1"
                                IntervalType="Days"
                                RangePadding="Additional"
                                ShowMajorGridLines="True" />
                        </chart:SfCartesianChart.XAxes>

                        <chart:SfCartesianChart.YAxes>
                            <chart:NumericalAxis
                                IsVisible="True"
                                RangePadding="Additional"
                                ShowMajorGridLines="False"
                                ShowMinorGridLines="False" />
                        </chart:SfCartesianChart.YAxes>

                        <chart:SfCartesianChart.Series>
                            <chart:ScatterSeries
                                x:Name="scatterSeries1"
                                EnableTooltip="true"
                                ItemsSource="{Binding Graficos.DadosGraficosDispersao}"
                                LegendIcon="Circle"
                                PaletteBrushes="{Binding Graficos.DadosGraficosDispersaoCores}"
                                PointHeight="15"
                                PointWidth="15"
                                XBindingPath="dataLote"
                                YBindingPath="Score" />
                        </chart:SfCartesianChart.Series>
                    </chart:SfCartesianChart>
                </Grid>

                <Grid
                    Grid.Row="0"
                    IsVisible="{Binding ISIAcometentoVisible}"
                    RowDefinitions="*">
                    <chart:SfCartesianChart
                        x:Name="chartAcometimento"
                        Grid.Row="0"
                        HorizontalOptions="Fill"
                        Series="{Binding AcometimentoSeriesCollection}"
                        VerticalOptions="Fill">

                        <chart:SfCartesianChart.XAxes>
                            <chart:DateTimeAxis ShowMajorGridLines="True" />
                        </chart:SfCartesianChart.XAxes>

                        <chart:SfCartesianChart.YAxes>
                            <chart:NumericalAxis
                                IsVisible="True"
                                Maximum="{Binding AcometimentoMaximo}"
                                Minimum="0"
                                ShowMajorGridLines="False" />
                        </chart:SfCartesianChart.YAxes>

                        <chart:SfCartesianChart.Legend>
                            <chart:ChartLegend />
                        </chart:SfCartesianChart.Legend>

                        <chart:SfCartesianChart.TooltipBehavior>
                            <chart:ChartTooltipBehavior />
                        </chart:SfCartesianChart.TooltipBehavior>

                        <chart:SfCartesianChart.ZoomPanBehavior>
                            <chart:ChartZoomPanBehavior
                                EnablePanning="True"
                                EnablePinchZooming="True"
                                ZoomMode="X" />
                        </chart:SfCartesianChart.ZoomPanBehavior>
                    </chart:SfCartesianChart>
                </Grid>

                <StackLayout
                    Grid.Row="1"
                    Padding="20,2"
                    BackgroundColor="{StaticResource QuaseBranco}"
                    IsVisible="{Binding PrecisaMostraFiltros}">
                    <Label
                        Margin="0"
                        Padding="0"
                        FontSize="Micro"
                        Text="{safe:Translate Regional}" />
                    <Border
                        Margin="0"
                        Padding="5,0"
                        Background="Transparent"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="0">
                        <controls:RegionalComboBox
                            x:Name="regionalcombobox"
                            Command="{Binding AtualizaGraficosCommand}"
                            SelectedItem="{Binding FiltroRegionalSelecionada, Mode=TwoWay}" />
                    </Border>
                </StackLayout>

                <StackLayout
                    Grid.Row="2"
                    Padding="20,2"
                    BackgroundColor="{StaticResource QuaseBranco}"
                    IsVisible="{Binding PrecisaMostraFiltros}">
                    <Label
                        Margin="0"
                        Padding="0"
                        FontSize="Micro"
                        Text="{safe:Translate UnidadeEpidemiológica}" />
                    <Border
                        Margin="0"
                        Padding="5,0"
                        Background="Transparent"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="0">
                        <controls:UnidadeEpidemiologicaComboBox
                            x:Name="uecombobox"
                            Command="{Binding AtualizaGraficosCommand}"
                            SelectedItem="{Binding FiltroUESelecionada, Mode=TwoWay}" />
                    </Border>
                </StackLayout>

            </Grid>
        </Border>

        <Grid
            Grid.Row="2"
            Margin="5,0"
            Padding="2"
            ColumnDefinitions="Auto,*,Auto"
            IsVisible="{Binding IsLandscape, Converter={StaticResource InvertBoolean}}"
            RowDefinitions="50">

            <buttons:SfButton
                Grid.Column="0"
                Margin="2"
                BackgroundColor="{StaticResource FundoClarinhoBotao}"
                Command="{Binding AtualizaAgoraCommand}"
                CornerRadius="10"
                ShowIcon="False"
                Text="{safe:Translate AtualizarDados}"
                TextColor="{StaticResource PrimaryColor}" />

            <StackLayout Grid.Column="1" VerticalOptions="Center">
                <Label
                    Margin="0"
                    Padding="0"
                    FontAttributes="Bold"
                    FontSize="Micro"
                    HorizontalTextAlignment="Center"
                    Text="{safe:Translate ÚltimaSincronização}"
                    TextColor="LightGray"
                    VerticalTextAlignment="Center" />
                <Label
                    Margin="0"
                    Padding="0"
                    FontSize="Micro"
                    HorizontalTextAlignment="Center"
                    Text="{Binding LastSyncText}"
                    TextColor="LightGray"
                    VerticalTextAlignment="Center" />
            </StackLayout>

            <buttons:SfButton
                Grid.Row="0"
                Grid.Column="2"
                Margin="2"
                BackgroundColor="{StaticResource FundoClarinhoBotao}"
                Command="{Binding ShowHideFiltroCommand}"
                CornerRadius="10"
                ShowIcon="False"
                Text="{safe:Translate Filtros}"
                TextColor="{StaticResource PrimaryColor}" />
        </Grid>

        <controls:LoadingView
            x:Name="busyindicator"
            Grid.Row="1"
            Grid.RowSpan="2"
            HorizontalOptions="Fill"
            IsVisible="{Binding IsBusy}"
            Text="{safe:Translate AguardeAtualizandoDados}"
            VerticalOptions="Fill" />
    </Grid>
</ContentView>
